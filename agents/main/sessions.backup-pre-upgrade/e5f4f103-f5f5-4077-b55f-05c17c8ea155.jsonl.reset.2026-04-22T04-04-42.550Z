{"type":"message","id":"912b4b61","parentId":"5fb5c52f","timestamp":"2026-04-21T03:32:58.730Z","message":{"role":"toolResult","toolCallId":"read:153","toolName":"read","content":[{"type":"text","text":"echo \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\n\nCVE_25253_VULNERABLE=false\n\n# 检查配置项\nif ! check_cve_config \"CVE-2026-25253\" \"gateway.controlUi.allowCustomGatewayUrl\" \"false\"; then\n    CVE_25253_VULNERABLE=true\nfi\n\nif ! check_cve_config \"CVE-2026-25253\" \"gateway.websocket.verifyOrigin\" \"true\"; then\n    CVE_25253_VULNERABLE=true\nfi\n\nif ! check_cve_config \"CVE-2026-25253\" \"gateway.devicePairing.requireConfirmation\" \"true\"; then\n    CVE_25253_VULNERABLE=true\nfi\n\nif ! check_cve_config \"CVE-2026-25253\" \"gateway.rateLimit.localhostExempt\" \"false\"; then\n    CVE_25253_VULNERABLE=true\nfi\n\necho \"\"\necho \"【CVE-2026-32302 (反向代理绕过) 检查】\"\necho \"风险: 伪造认证身份\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\n\nCVE_32302_VULNERABLE=false\nAUTH_MODE=$(openclaw config get \"gateway.auth.mode\" 2>/dev/null || echo \"NOT_SET\")\n\nif [ \"$AUTH_MODE\" == \"trusted-proxy\" ]; then\n    echo \"⚠️  当前认证模式为 trusted-proxy，存在绕过风险\"\n    echo \"   建议: openclaw config set gateway.auth.mode \\\"token\\\"\"\n    CVE_32302_VULNERABLE=true\nelse\n    echo \"✅ 认证模式为 ${AUTH_MODE} (安全)\"\nfi\n\necho \"\"\necho \"【CVE-2026-29610 (命令劫持) 检查】\"\necho \"风险: PATH环境变量被篡改\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\n\nCVE_29610_VULNERABLE=false\n# 检查PATH中是否存在不安全的可写目录\necho \"检查PATH环境变量...\"\nIFS=':' read -ra PATH_DIRS <<< \"$PATH\"\nfor dir in \"${PATH_DIRS[@]}\"; do\n    if [ -d \"$dir\" ] && [ -w \"$dir\" ]; then\n        if [[ \"$dir\" == \"/tmp\"* ]] || [[ \"$dir\" == \"/var/tmp\"* ]] || [[ \"$dir\" == \".\"* ]]; then\n            echo \"⚠️  警告: ${dir} 可写且在PATH中 (${CVE_29610_VULNERABLE})\"\n            CVE_29610_VULNERABLE=true\n        fi\n    fi\ndone\n\nif [ \"$CVE_29610_VULNERABLE\" = false ]; then\n    echo \"✅ PATH环境变量安全\"\nfi\n\necho \"\"\necho \"【CVE-2026-28466 (Node审批绕过) 检查】\"\necho \"风险: 绕过执行审批机制\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\n\nOPENCLAW_VERSION=$(openclaw version 2>/dev/null | grep -oE '[0-9]+\\.[0-9]+\\.[0-9]+' | head -1 || echo \"0.0.0\")\n\n# 检查版本是否 >= 2026.3.12\nif [[ \"$OPENCLAW_VERSION\" < \"2026.3.12\" ]]; then\n    echo \"❌ OpenClaw版本 ${OPENCLAW_VERSION} 存在漏洞\"\n    echo \"   建议: 升级到 2026.3.12 或更高版本\"\n    CVE_28466_VULNERABLE=true\nelse\n    echo \"✅ OpenClaw版本 ${OPENCLAW_VERSION} (已修复)\"\n    CVE_28466_VULNERABLE=false\nfi\n\necho \"\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\necho \"📊 CVE检查总结\"\necho \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"\n\nCRITICAL_COUNT=0\nHIGH_COUNT=0\n\nif [ \"$CVE_25253_VULNERABLE\" = true ]; then\n    echo \"🔴 CVE-2026-25253: 存在漏洞 (Critical)\"\n    CRITICAL_COUNT=$((CRITICAL_COUNT + 1))\nelse\n    echo \"✅ CVE-2026-25253: 已修复\"\nfi\n\nif [ \"$CVE_32302_VULNERABLE\" = true ]; then\n    echo \"🔴 CVE-2026-32302: 存在漏洞 (Critical)\"\n    CRITICAL_COUNT=$((CRITICAL_COUNT + 1))\nelse\n    echo \"✅ CVE-2026-32302: 已修复/安全\"\nfi\n\nif [ \"$CVE_29610_VULNERABLE\" = true ]; then\n    echo \"🟠 CVE-2026-29610: 存在风险 (High)\"\n\n[220 more lines in file. Use offset=150 to continue.]"}],"isError":false,"timestamp":1776742378729}}
