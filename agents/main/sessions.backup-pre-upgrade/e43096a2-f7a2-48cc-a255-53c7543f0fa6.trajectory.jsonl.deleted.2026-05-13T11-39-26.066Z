me":"@openclaw/zai-provider","version":"2026.4.20","description":"OpenClaw Z.AI provider plugin","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zai/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zai"},{"id":"zalo","name":"@openclaw/zalo","version":"2026.4.20","description":"OpenClaw Zalo channel plugin","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zalo/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zalo"},{"id":"zalouser","name":"@openclaw/zalouser","version":"2026.4.20","description":"OpenClaw Zalo Personal Account plugin via native zca-js integration","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zalouser/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zalouser"}]},"skills":{"snapshotVersion":1777512807550,"entries":[{"id":"agent-browser","name":"agent-browser","description":"Browser automation CLI for AI agents. Use when the user needs to interact with websites, including navigating pages, filling forms, clicking buttons, taking screenshots, extracting data, testing web apps, or automating any browser task. Triggers include requests to \"open a website\", \"fill out a form\", \"click a button\", \"take a screenshot\", \"scrape data from a page\", \"test this web app\", \"login to a site\", \"automate browser actions\", or any task requiring programmatic web interaction.","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"coze-asr","name":"coze-asr","description":"Convert speech audio to text using Coze ASR. Use when you need to transcribe spoken content from a remote audio URL or a local audio file into plain text.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"coze-image-gen","name":"coze-image-gen","description":"Generate one or more images from text prompts using Coze image generation. Use when you need to create images from a natural-language prompt, produce multiple image variants, or generate sequential frames from the same prompt.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"coze-tts","name":"coze-tts","description":"Convert text to speech using Coze TTS. Use when you need to synthesize spoken audio from one text input or multiple text segments, optionally with a specific speaker, format, sample rate, or speech settings.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-bitable","name":"feishu-bitable","description":"飞书多维表格（Bitable）的创建、查询、编辑和管理工具。包含 27 种字段类型支持、高级筛选、批量操作和视图管理。\n\n**当以下情况时使用此 Skill**：\n(1) 需要创建或管理飞书多维表格 App\n(2) 需要在多维表格中新增、查询、修改、删除记录（行数据）\n(3) 需要管理字段（列）、视图、数据表\n(4) 用户提到\"多维表格\"、\"bitable\"、\"数据表\"、\"记录\"、\"字段\"\n(5) 需要批量导入数据或批量更新多维表格","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-calendar","name":"feishu-calendar","description":"飞书日历与日程管理工具集。包含日历管理、日程管理、参会人管理、忙闲查询。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-channel-rules","name":"feishu-channel-rules","description":"Lark/Feishu channel output rules. Always active in Lark conversations.","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-create-doc","name":"feishu-create-doc","description":"创建飞书云文档。从 Lark-flavored Markdown 内容创建新的飞书云文档，支持指定创建位置（文件夹/知识库/知识空间）。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-doc","name":"feishu-doc","description":"Feishu document read/write operations. Activate when user mentions Feishu docs, cloud docs, or docx links.","filePath":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc","source":"openclaw-extra","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc","origin":"top-level","path":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-drive","name":"feishu-drive","description":"Feishu cloud storage file management. Activate when user mentions cloud space, folders, drive.","filePath":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive","source":"openclaw-extra","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive","origin":"top-level","path":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-fetch-doc","name":"feishu-fetch-doc","description":"获取飞书云文档内容。返回文档的 Markdown 内容，支持处理文档中的图片、文件和画板（需配合 feishu_doc_media 工具）。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-im-read","name":"feishu-im-read","description":"飞书 IM 消息读取工具使用指南，覆盖会话消息获取、话题回复读取、跨会话消息搜索、图片/文件资源下载。\n\n**当以下情况时使用此 Skill**:\n(1) 需要获取群聊或单聊的历史消息\n(2) 需要读取话题（thread）内的回复消息\n(3) 需要跨会话搜索消息（按关键词、发送者、时间等条件）\n(4) 消息中包含图片、文件、音频、视频，需要下载\n(5) 用户提到\"聊天记录\"、\"消息\"、\"群里说了什么\"、\"话题回复\"、\"搜索消息\"、\"图片\"、\"文件下载\"\n(6) 需要按时间范围过滤消息、分页获取更多消息","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-perm","name":"feishu-perm","description":"Feishu permission management for documents and files. Activate when user mentions sharing, permissions, collaborators.","filePath":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm","source":"openclaw-extra","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm","origin":"top-level","path":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-task","name":"feishu-task","description":"飞书任务管理工具,用于创建、查询、更新任务和清单。\n\n**当以下情况时使用此 Skill**:\n(1) 需要创建、查询、更新任务\n(2) 需要创建、管理任务清单\n(3) 需要查看任务列表或清单内的任务\n(4) 用户提到\"任务\"、\"待办\"、\"to-do\"、\"清单\"、\"task\"\n(5) 需要设置任务负责人、关注人、截止时间","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-troubleshoot","name":"feishu-troubleshoot","description":"飞书插件问题排查工具。包含常见问题 FAQ 和深度诊断命令（/feishu_doctor）。\n\n常见问题可随时查阅。诊断命令用于排查复杂问题（多次授权仍失败、自动授权无法解决等），\n会检查账户配置、API 连通性、应用权限、用户授权状态，并生成详细的诊断报告和解决方案。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-troubleshoot/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-troubleshoot","source":"openclaw-extra","