ersion":"2026.4.20","description":"OpenClaw Z.AI provider plugin","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zai/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zai"},{"id":"zalo","name":"@openclaw/zalo","version":"2026.4.20","description":"OpenClaw Zalo channel plugin","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zalo/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zalo"},{"id":"zalouser","name":"@openclaw/zalouser","version":"2026.4.20","description":"OpenClaw Zalo Personal Account plugin via native zca-js integration","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zalouser/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zalouser"}]},"skills":{"snapshotVersion":0,"entries":[{"id":"agent-browser","name":"agent-browser","description":"Browser automation CLI for AI agents. Use when the user needs to interact with websites, including navigating pages, filling forms, clicking buttons, taking screenshots, extracting data, testing web apps, or automating any browser task. Triggers include requests to \"open a website\", \"fill out a form\", \"click a button\", \"take a screenshot\", \"scrape data from a page\", \"test this web app\", \"login to a site\", \"automate browser actions\", or any task requiring programmatic web interaction.","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"coze-asr","name":"coze-asr","description":"Convert speech audio to text using Coze ASR. Use when you need to transcribe spoken content from a remote audio URL or a local audio file into plain text.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"coze-image-gen","name":"coze-image-gen","description":"Generate one or more images from text prompts using Coze image generation. Use when you need to create images from a natural-language prompt, produce multiple image variants, or generate sequential frames from the same prompt.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"coze-tts","name":"coze-tts","description":"Convert text to speech using Coze TTS. Use when you need to synthesize spoken audio from one text input or multiple text segments, optionally with a specific speaker, format, sample rate, or speech settings.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-bitable","name":"feishu-bitable","description":"飞书多维表格（Bitable）的创建、查询、编辑和管理工具。包含 27 种字段类型支持、高级筛选、批量操作和视图管理。\n\n**当以下情况时使用此 Skill**：\n(1) 需要创建或管理飞书多维表格 App\n(2) 需要在多维表格中新增、查询、修改、删除记录（行数据）\n(3) 需要管理字段（列）、视图、数据表\n(4) 用户提到\"多维表格\"、\"bitable\"、\"数据表\"、\"记录\"、\"字段\"\n(5) 需要批量导入数据或批量更新多维表格","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-calendar","name":"feishu-calendar","description":"飞书日历与日程管理工具集。包含日历管理、日程管理、参会人管理、忙闲查询。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-channel-rules","name":"feishu-channel-rules","description":"Lark/Feishu channel output rules. Always active in Lark conversations.","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-channel-rules/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-create-doc","name":"feishu-create-doc","description":"创建飞书云文档。从 Lark-flavored Markdown 内容创建新的飞书云文档，支持指定创建位置（文件夹/知识库/知识空间）。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-create-doc/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-doc","name":"feishu-doc","description":"Feishu document read/write operations. Activate when user mentions Feishu docs, cloud docs, or docx links.","filePath":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc","source":"openclaw-extra","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc","origin":"top-level","path":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-drive","name":"feishu-drive","description":"Feishu cloud storage file management. Activate when user mentions cloud space, folders, drive.","filePath":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive","source":"openclaw-extra","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive","origin":"top-level","path":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-fetch-doc","name":"feishu-fetch-doc","description":"获取飞书云文档内容。返回文档的 Markdown 内容，支持处理文档中的图片、文件和画板（需配合 feishu_doc_media 工具）。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-fetch-doc/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-im-read","name":"feishu-im-read","description":"飞书 IM 消息读取工具使用指南，覆盖会话消息获取、话题回复读取、跨会话消息搜索、图片/文件资源下载。\n\n**当以下情况时使用此 Skill**:\n(1) 需要获取群聊或单聊的历史消息\n(2) 需要读取话题（thread）内的回复消息\n(3) 需要跨会话搜索消息（按关键词、发送者、时间等条件）\n(4) 消息中包含图片、文件、音频、视频，需要下载\n(5) 用户提到\"聊天记录\"、\"消息\"、\"群里说了什么\"、\"话题回复\"、\"搜索消息\"、\"图片\"、\"文件下载\"\n(6) 需要按时间范围过滤消息、分页获取更多消息","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-im-read/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-perm","name":"feishu-perm","description":"Feishu permission management for documents and files. Activate when user mentions sharing, permissions, collaborators.","filePath":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm","source":"openclaw-extra","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm","origin":"top-level","path":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-task","name":"feishu-task","description":"飞书任务管理工具,用于创建、查询、更新任务和清单。\n\n**当以下情况时使用此 Skill**:\n(1) 需要创建、查询、更新任务\n(2) 需要创建、管理任务清单\n(3) 需要查看任务列表或清单内的任务\n(4) 用户提到\"任务\"、\"待办\"、\"to-do\"、\"清单\"、\"task\"\n(5) 需要设置任务负责人、关注人、截止时间","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-task/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-troubleshoot","name":"feishu-troubleshoot","description":"飞书插件问题排查工具。包含常见问题 FAQ 和深度诊断命令（/feishu_doctor）。\n\n常见问题可随时查阅。诊断命令用于排查复杂问题（多次授权仍失败、自动授权无法解决等），\n会检查账户配置、API 连通性、应用权限、用户授权状态，并生成详细的诊断报告和解决方案。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-troubleshoot/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-troubleshoot","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-troubleshoot","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-troubleshoot/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-update-doc","name":"feishu-update-doc","description":"更新飞书云文档。支持 7 种更新模式：追加、覆盖、定位替换、全文替换、前/后插入、删除。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-update-doc/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-update-doc","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-update-doc","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-update-doc/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-wiki","name":"feishu-wiki","description":"Feishu knowledge base navigation. Activate when user mentions knowledge base, wiki, or wiki links.","filePath":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-wiki/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-wiki","source":"openclaw-extra","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-wiki","origin":"top-level","path":"/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-wiki/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"find-skills","name":"find-skills","description":"Highest-priority skill discovery flow. MUST trigger when users ask to find/install skills (e.g. 技能, 找技能, find-skill, find-skills, install skill). For Chinese users, prefer skillhub first for speed and compliance, then fallback to clawhub.","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/find-skills/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/find-skills","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/find-skills","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/find-skills/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"healthcheck","name":"healthcheck","description":"Host security hardening and risk-tolerance configuration for OpenClaw deployments. Use when a user asks for security audits, firewall/SSH/update hardening, risk posture, exposure review, OpenClaw cron scheduling for periodic checks, or version status checks on a machine running OpenClaw (laptop, workstation, Pi, VPS).","filePath":"/usr/lib/node_modules/openclaw/skills/healthcheck/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/skills/healthcheck","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/healthcheck","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/healthcheck/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"node-connect","name":"node-connect","description":"Diagnose OpenClaw node connection and pairing failures for Android, iOS, and macOS companion apps. Use when QR/setup code/manual connect fails, local Wi-Fi works but VPS/tailnet does not, or errors mention pairing required, unauthorized, bootstrap token invalid or expired, gateway.bind, gateway.remote.url, Tailscale, or plugins.entries.device-pair.config.publicUrl.","filePath":"/usr/lib/node_modules/openclaw/skills/node-connect/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/skills/node-connect","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/node-connect","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/node-connect/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"openclaw-faq","name":"openclaw-faq","description":"OpenClaw/龙虾/扣子常见问题解答助手。当用户遇到启动问题、服务中断、模型调用失败、飞书集成问题，或对 OpenClaw、Coze、龙虾有疑问时召回此技能。\n\n通过阅读官方 FAQ 文档帮助用户找到解决方案或指导操作步骤。","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/openclaw-faq/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/openclaw-faq","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/openclaw-faq","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/openclaw-faq/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"skill-creator","name":"skill-creator","description":"Create, edit, improve, or audit AgentSkills. Use when creating a new skill from scratch or when asked to improve, review, audit, tidy up, or clean up an existing skill or SKILL.md file. Also use when editing or restructuring a skill directory (moving files to references/ or scripts/, removing stale content, validating against the AgentSkills spec). Triggers on phrases like \"create a skill\", \"author a skill\", \"tidy up a skill\", \"improve this skill\", \"review the skill\", \"clean up the skill\", \"audit the skill\".","filePath":"/usr/lib/node_modules/openclaw/skills/skill-creator/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/skills/skill-creator","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/skill-creator","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/skill-creator/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"skillhub-preference","name":"skillhub-preference","description":"Prefer `skillhub` for skill discovery/install/update, then fallback to `clawhub` when unavailable or no match. Use when users ask about skills, 插件, or capability extension.","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"taskflow","name":"taskflow","description":"Use when work should span one or more detached tasks but still behave like one job with a single owner context. TaskFlow is the durable flow substrate under authoring layers like Lobster, ACPX, plugins, or plain code. Keep conditional logic in the caller; use TaskFlow for flow identity, child-task linkage, waiting state, revision-checked mutations, and user-facing emergence.","filePath":"/usr/lib/node_modules/openclaw/skills/taskflow/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/skills/taskflow","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/taskflow","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/taskflow/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"taskflow-inbox-triage","name":"taskflow-inbox-triage","description":"Example TaskFlow authoring pattern for inbox triage. Use when messages need different treatment based on intent, with some routes notifying immediately, some waiting on outside answers, and others rolling into a later summary.","filePath":"/usr/lib/node_modules/openclaw/skills/taskflow-inbox-triage/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/skills/taskflow-inbox-triage","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/taskflow-inbox-triage","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/taskflow-inbox-triage/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"tmux","name":"tmux","description":"Remote-control tmux sessions for interactive CLIs by sending keystrokes and scraping pane output.","filePath":"/usr/lib/node_modules/openclaw/skills/tmux/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/skills/tmux","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/tmux","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/tmux/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"using-coze-cli","name":"using-coze-cli","description":"Coze CLI 共享基础：安装、认证登录(OAuth)、组织与空间切换、配置管理、全局执行原则、安全规则、错误码处理、代理配置。当用户首次使用 coze-cli、需要登录授权、遇到权限不足、切换组织/空间、或任何操作前的基础检查时触发。","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/using-coze-cli/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/using-coze-cli","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/using-coze-cli","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/using-coze-cli/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"weather","name":"weather","description":"Get current weather and forecasts via wttr.in or Open-Meteo. Use when: user asks about weather, temperature, or forecasts for any location. NOT for: historical weather data, severe weather alerts, or detailed meteorological analysis. No API key needed.","filePath":"/usr/lib/node_modules/openclaw/skills/weather/SKILL.md","baseDir":"/usr/lib/node_modules/openclaw/skills/weather","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/weather","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/weather/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"wecom-contact-lookup","name":"wecom-contact-lookup","description":"通讯录成员查询技能，基于 MCP tool 协议封装的 `get_userlist` 接口，获取当前用户可见范围内的通讯录成员，支持按姓名/别名本地筛选匹配。返回 userid、姓名和别名。⚠️ 仅返回当前用户有权限查看的成员，非全量成员。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-contact-lookup/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-contact-lookup","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-contact-lookup","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-contact-lookup/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-doc-manager","name":"wecom-doc-manager","description":"企业微信文档管理技能。提供文档的创建、读取和编辑能力，支持通过 docid 或文档 URL 操作企业微信文档（doc_type=3）和智能表格（doc_type=10）。适用场景：(1) 以 Markdown 格式导出获取文档完整内容（异步轮询） (2) 新建文档或智能表格 (3) 用 Markdown 格式覆写文档内容。当用户需要查看文档内容、创建新文档、编辑文档正文时触发此 Skill。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-doc-manager/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-doc-manager","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-doc-manager","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-doc-manager/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-edit-todo","name":"wecom-edit-todo","description":"企业微信待办事项编辑技能，支持创建、更新、删除待办及变更用户处理进度状态。在用户说\"帮我创建一个待办\"、\"把这个任务分派给张三\"、\"标记待办完成\"、\"删掉那个待办\"、\"帮我建个提醒\"、\"更新一下待办内容\"、\"把提醒时间改到下周\"、\"接受这个待办\"、\"拒绝这个待办\"等需要对待办进行写操作的场景时使用。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-edit-todo/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-edit-todo","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-edit-todo","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-edit-todo/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-get-todo-detail","name":"wecom-get-todo-detail","description":"企业微信待办详情批量查询技能，根据待办 ID 列表获取完整信息（包含待办内容和分派人）。在用户说\"看看这个待办的详情\"、\"待办内容是什么\"、\"这个待办分派给谁了\"、\"告诉我待办的具体信息\"等需要查看待办完整内容的场景时使用。通常配合 wecom-get-todo-list 使用——先获取待办 ID 列表，再用本技能获取详情。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-detail/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-detail","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-detail","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-detail/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-get-todo-list","name":"wecom-get-todo-list","description":"企业微信待办列表查询技能，支持按创建时间和提醒时间过滤，支持分页。在用户说\"看看我的待办列表\"、\"我有哪些待办\"、\"这周的待办有哪些\"、\"最近有什么待办\"、\"查一下我的待办\"、\"列出所有待办\"等需要浏览待办概览的场景时使用。注意：此技能仅返回待办概要信息（不含内容和分派人），如需完整详情请配合 wecom-get-todo-detail 使用。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-list/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-list","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-list","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-list/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-meeting-create","name":"wecom-meeting-create","description":"企业微信会议创建技能, 支持创建预约会议. 当用户需要\"创建会议\", \"预约会议\", \"约会议\", \"安排会议\"时触发.","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-create/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-create","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-create","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-create/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-meeting-manage","name":"wecom-meeting-manage","description":"企业微信会议管理技能, 支持取消会议和更新会议受邀成员. 当用户需要\"取消会议\", \"删除会议\", \"修改会议成员\", \"添加会议参与人\", \"移除会议成员\"时触发.","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-manage/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-manage","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-manage","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-manage/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-meeting-query","name":"wecom-meeting-query","description":"企业微信会议查询技能, 支持查询会议列表, 获取会议详情, 按关键词查找会议. 当用户需要\"查看会议\", \"查询会议列表\", \"会议详情\", \"什么时候开会\", \"有哪些会议\", \"查找会议\"时触发.","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-query/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-query","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-query","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-meeting-query/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-msg","name":"wecom-msg","description":"企业微信消息技能。提供会话列表查询、消息记录拉取（支持文本/图片/文件/语音/视频）、多媒体文件获取和文本消息发送能力。当用户需要\"查看消息\"、\"看聊天记录\"、\"发消息给某人\"、\"最近有什么消息\"、\"给群里发消息\"、\"看看发了什么图片/文件\"时触发。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-msg/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-msg","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-msg","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-msg/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-preflight","name":"wecom-preflight","description":"企业微信插件前置条件检查。在执行任何 wecom_mcp 操作前，通过 shell 命令检查工具权限配置（profile 和白名单），若缺失则自动修复并提示用户重启 Gateway。所有使用 wecom_mcp 的技能都应在首次调用前执行此检查。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-preflight/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-preflight","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-preflight","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-preflight/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-schedule","name":"wecom-schedule","description":"企业微信日程管理技能。适用于用户对企业微信日程的各类管理需求。当用户需要：(1) 查询指定时间范围内的日程列表或获取日程详细信息（标题、时间、地点、参与者等），(2) 创建新日程并设置提醒、参与人等，(3) 修改已有日程的标题、时间、地点等信息或取消日程，(4) 添加或移除日程参与人，(5) 查询多个成员的闲忙状态并分析共同空闲时段以安排会议时使用此技能。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-schedule/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-schedule","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-schedule","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-schedule/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-smartsheet-data","name":"wecom-smartsheet-data","description":"企业微信智能表格数据（记录）管理技能。提供智能表格记录的增删改查能力。适用场景：(1) 查询子表全部记录 (2) 添加一行或多行记录 (3) 更新已有记录 (4) 删除记录。当用户需要读取表格数据、写入新数据、修改或删除表格行时触发此 Skill。支持通过 docid 或文档 URL 定位文档。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-data/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-data","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-data","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-data/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"wecom-smartsheet-schema","name":"wecom-smartsheet-schema","description":"企业微信智能表格结构管理技能。提供子表（Sheet）和字段（Field/列）的增删改查能力。适用场景：(1) 查询智能表格的子表列表 (2) 添加、更新、删除子表 (3) 查询子表的字段/列信息 (4) 添加、更新、删除字段/列。当用户需要管理智能表格的表结构、列定义、子表配置时触发此 Skill。支持通过 docid 或文档 URL 定位文档。","filePath":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-schema/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-schema","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-schema","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-schema/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true}]},"prompting":{"skillsPrompt":"\n\nThe following skills provide specialized instructions for specific tasks.\nUse the read tool to load a skill's file when the task matches its description.\nWhen a skill file references a relative path, resolve it against the skill directory (parent of SKILL.md / dirname of the path) and use that absolute path in tool commands.\n\n<available_skills>\n  <skill>\n    <name>agent-browser</name>\n    <description>Browser automation CLI for AI agents. Use when the user needs to interact with websites, including navigating pages, filling forms, clicking buttons, taking screenshots, extracting data, testing web apps, or automating any browser task. Triggers include requests to &quot;open a website&quot;, &quot;fill out a form&quot;, &quot;click a button&quot;, &quot;take a screenshot&quot;, &quot;scrape data from a page&quot;, &quot;test this web app&quot;, &quot;login to a site&quot;, &quot;automate browser actions&quot;, or any task requiring programmatic web interaction.</description>\n    <location>/workspace/projects/workspace/skills/agent-browser/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>coze-asr</name>\n    <description>Convert speech audio to text using Coze ASR. Use when you need to transcribe spoken content from a remote audio URL or a local audio file into plain text.</description>\n    <location>/workspace/projects/extensions/coze-openclaw-plugin/skills/coze-asr/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>coze-image-gen</name>\n    <description>Generate one or more images from text prompts using Coze image generation. Use when you need to create images from a natural-language prompt, produce multiple image variants, or generate sequential frames from the same prompt.</description>\n    <location>/workspace/projects/extensions/coze-openclaw-plugin/skills/coze-image-gen/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>coze-tts</name>\n    <description>Convert text to speech using Coze TTS. Use when you need to synthesize spoken audio from one text input or multiple text segments, optionally with a specific speaker, format, sample rate, or speech settings.</description>\n    <location>/workspace/projects/extensions/coze-openclaw-plugin/skills/coze-tts/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-bitable</name>\n    <description>飞书多维表格（Bitable）的创建、查询、编辑和管理工具。包含 27 种字段类型支持、高级筛选、批量操作和视图管理。\n\n**当以下情况时使用此 Skill**：\n(1) 需要创建或管理飞书多维表格 App\n(2) 需要在多维表格中新增、查询、修改、删除记录（行数据）\n(3) 需要管理字段（列）、视图、数据表\n(4) 用户提到&quot;多维表格&quot;、&quot;bitable&quot;、&quot;数据表&quot;、&quot;记录&quot;、&quot;字段&quot;\n(5) 需要批量导入数据或批量更新多维表格</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-bitable/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-calendar</name>\n    <description>飞书日历与日程管理工具集。包含日历管理、日程管理、参会人管理、忙闲查询。</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-calendar/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-channel-rules</name>\n    <description>Lark/Feishu channel output rules. Always active in Lark conversations.</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-channel-rules/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-create-doc</name>\n    <description>创建飞书云文档。从 Lark-flavored Markdown 内容创建新的飞书云文档，支持指定创建位置（文件夹/知识库/知识空间）。</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-create-doc/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-doc</name>\n    <description>Feishu document read/write operations. Activate when user mentions Feishu docs, cloud docs, or docx links.</description>\n    <location>/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-doc/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-drive</name>\n    <description>Feishu cloud storage file management. Activate when user mentions cloud space, folders, drive.</description>\n    <location>/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-drive/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-fetch-doc</name>\n    <description>获取飞书云文档内容。返回文档的 Markdown 内容，支持处理文档中的图片、文件和画板（需配合 feishu_doc_media 工具）。</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-fetch-doc/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-im-read</name>\n    <description>飞书 IM 消息读取工具使用指南，覆盖会话消息获取、话题回复读取、跨会话消息搜索、图片/文件资源下载。\n\n**当以下情况时使用此 Skill**:\n(1) 需要获取群聊或单聊的历史消息\n(2) 需要读取话题（thread）内的回复消息\n(3) 需要跨会话搜索消息（按关键词、发送者、时间等条件）\n(4) 消息中包含图片、文件、音频、视频，需要下载\n(5) 用户提到&quot;聊天记录&quot;、&quot;消息&quot;、&quot;群里说了什么&quot;、&quot;话题回复&quot;、&quot;搜索消息&quot;、&quot;图片&quot;、&quot;文件下载&quot;\n(6) 需要按时间范围过滤消息、分页获取更多消息</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-im-read/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-perm</name>\n    <description>Feishu permission management for documents and files. Activate when user mentions sharing, permissions, collaborators.</description>\n    <location>/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-perm/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-task</name>\n    <description>飞书任务管理工具,用于创建、查询、更新任务和清单。\n\n**当以下情况时使用此 Skill**:\n(1) 需要创建、查询、更新任务\n(2) 需要创建、管理任务清单\n(3) 需要查看任务列表或清单内的任务\n(4) 用户提到&quot;任务&quot;、&quot;待办&quot;、&quot;to-do&quot;、&quot;清单&quot;、&quot;task&quot;\n(5) 需要设置任务负责人、关注人、截止时间</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-task/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-troubleshoot</name>\n    <description>飞书插件问题排查工具。包含常见问题 FAQ 和深度诊断命令（/feishu_doctor）。\n\n常见问题可随时查阅。诊断命令用于排查复杂问题（多次授权仍失败、自动授权无法解决等），\n会检查账户配置、API 连通性、应用权限、用户授权状态，并生成详细的诊断报告和解决方案。</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-troubleshoot/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-update-doc</name>\n    <description>更新飞书云文档。支持 7 种更新模式：追加、覆盖、定位替换、全文替换、前/后插入、删除。</description>\n    <location>/workspace/projects/extensions/openclaw-lark/skills/feishu-update-doc/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>feishu-wiki</name>\n    <description>Feishu knowledge base navigation. Activate when user mentions knowledge base, wiki, or wiki links.</description>\n    <location>/usr/lib/node_modules/openclaw/dist/extensions/feishu/skills/feishu-wiki/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>find-skills</name>\n    <description>Highest-priority skill discovery flow. MUST trigger when users ask to find/install skills (e.g. 技能, 找技能, find-skill, find-skills, install skill). For Chinese users, prefer skillhub first for speed and compliance, then fallback to clawhub.</description>\n    <location>/workspace/projects/workspace/skills/find-skills/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>healthcheck</name>\n    <description>Host security hardening and risk-tolerance configuration for OpenClaw deployments. Use when a user asks for security audits, firewall/SSH/update hardening, risk posture, exposure review, OpenClaw cron scheduling for periodic checks, or version status checks on a machine running OpenClaw (laptop, workstation, Pi, VPS).</description>\n    <location>/usr/lib/node_modules/openclaw/skills/healthcheck/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>node-connect</name>\n    <description>Diagnose OpenClaw node connection and pairing failures for Android, iOS, and macOS companion apps. Use when QR/setup code/manual connect fails, local Wi-Fi works but VPS/tailnet does not, or errors mention pairing required, unauthorized, bootstrap token invalid or expired, gateway.bind, gateway.remote.url, Tailscale, or plugins.entries.device-pair.config.publicUrl.</description>\n    <location>/usr/lib/node_modules/openclaw/skills/node-connect/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>openclaw-faq</name>\n    <description>OpenClaw/龙虾/扣子常见问题解答助手。当用户遇到启动问题、服务中断、模型调用失败、飞书集成问题，或对 OpenClaw、Coze、龙虾有疑问时召回此技能。\n\n通过阅读官方 FAQ 文档帮助用户找到解决方案或指导操作步骤。</description>\n    <location>/workspace/projects/extensions/coze-openclaw-plugin/skills/openclaw-faq/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>skill-creator</name>\n    <description>Create, edit, improve, or audit AgentSkills. Use when creating a new skill from scratch or when asked to improve, review, audit, tidy up, or clean up an existing skill or SKILL.md file. Also use when editing or restructuring a skill directory (moving files to references/ or scripts/, removing stale content, validating against the AgentSkills spec). Triggers on phrases like &quot;create a skill&quot;, &quot;author a skill&quot;, &quot;tidy up a skill&quot;, &quot;improve this skill&quot;, &quot;review the skill&quot;, &quot;clean up the skill&quot;, &quot;audit the skill&quot;.</description>\n    <location>/usr/lib/node_modules/openclaw/skills/skill-creator/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>skillhub-preference</name>\n    <description>Prefer `skillhub` for skill discovery/install/update, then fallback to `clawhub` when unavailable or no match. Use when users ask about skills, 插件, or capability extension.</description>\n    <location>/workspace/projects/workspace/skills/skillhub-preference/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>taskflow</name>\n    <description>Use when work should span one or more detached tasks but still behave like one job with a single owner context. TaskFlow is the durable flow substrate under authoring layers like Lobster, ACPX, plugins, or plain code. Keep conditional logic in the caller; use TaskFlow for flow identity, child-task linkage, waiting state, revision-checked mutations, and user-facing emergence.</description>\n    <location>/usr/lib/node_modules/openclaw/skills/taskflow/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>taskflow-inbox-triage</name>\n    <description>Example TaskFlow authoring pattern for inbox triage. Use when messages need different treatment based on intent, with some routes notifying immediately, some waiting on outside answers, and others rolling into a later summary.</description>\n    <location>/usr/lib/node_modules/openclaw/skills/taskflow-inbox-triage/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>tmux</name>\n    <description>Remote-control tmux sessions for interactive CLIs by sending keystrokes and scraping pane output.</description>\n    <location>/usr/lib/node_modules/openclaw/skills/tmux/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>using-coze-cli</name>\n    <description>Coze CLI 共享基础：安装、认证登录(OAuth)、组织与空间切换、配置管理、全局执行原则、安全规则、错误码处理、代理配置。当用户首次使用 coze-cli、需要登录授权、遇到权限不足、切换组织/空间、或任何操作前的基础检查时触发。</description>\n    <location>/workspace/projects/workspace/skills/using-coze-cli/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>weather</name>\n    <description>Get current weather and forecasts via wttr.in or Open-Meteo. Use when: user asks about weather, temperature, or forecasts for any location. NOT for: historical weather data, severe weather alerts, or detailed meteorological analysis. No API key needed.</description>\n    <location>/usr/lib/node_modules/openclaw/skills/weather/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-contact-lookup</name>\n    <description>通讯录成员查询技能，基于 MCP tool 协议封装的 `get_userlist` 接口，获取当前用户可见范围内的通讯录成员，支持按姓名/别名本地筛选匹配。返回 userid、姓名和别名。⚠️ 仅返回当前用户有权限查看的成员，非全量成员。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-contact-lookup/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-doc-manager</name>\n    <description>企业微信文档管理技能。提供文档的创建、读取和编辑能力，支持通过 docid 或文档 URL 操作企业微信文档（doc_type=3）和智能表格（doc_type=10）。适用场景：(1) 以 Markdown 格式导出获取文档完整内容（异步轮询） (2) 新建文档或智能表格 (3) 用 Markdown 格式覆写文档内容。当用户需要查看文档内容、创建新文档、编辑文档正文时触发此 Skill。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-doc-manager/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-edit-todo</name>\n    <description>企业微信待办事项编辑技能，支持创建、更新、删除待办及变更用户处理进度状态。在用户说&quot;帮我创建一个待办&quot;、&quot;把这个任务分派给张三&quot;、&quot;标记待办完成&quot;、&quot;删掉那个待办&quot;、&quot;帮我建个提醒&quot;、&quot;更新一下待办内容&quot;、&quot;把提醒时间改到下周&quot;、&quot;接受这个待办&quot;、&quot;拒绝这个待办&quot;等需要对待办进行写操作的场景时使用。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-edit-todo/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-get-todo-detail</name>\n    <description>企业微信待办详情批量查询技能，根据待办 ID 列表获取完整信息（包含待办内容和分派人）。在用户说&quot;看看这个待办的详情&quot;、&quot;待办内容是什么&quot;、&quot;这个待办分派给谁了&quot;、&quot;告诉我待办的具体信息&quot;等需要查看待办完整内容的场景时使用。通常配合 wecom-get-todo-list 使用——先获取待办 ID 列表，再用本技能获取详情。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-detail/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-get-todo-list</name>\n    <description>企业微信待办列表查询技能，支持按创建时间和提醒时间过滤，支持分页。在用户说&quot;看看我的待办列表&quot;、&quot;我有哪些待办&quot;、&quot;这周的待办有哪些&quot;、&quot;最近有什么待办&quot;、&quot;查一下我的待办&quot;、&quot;列出所有待办&quot;等需要浏览待办概览的场景时使用。注意：此技能仅返回待办概要信息（不含内容和分派人），如需完整详情请配合 wecom-get-todo-detail 使用。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-get-todo-list/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-meeting-create</name>\n    <description>企业微信会议创建技能, 支持创建预约会议. 当用户需要&quot;创建会议&quot;, &quot;预约会议&quot;, &quot;约会议&quot;, &quot;安排会议&quot;时触发.</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-meeting-create/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-meeting-manage</name>\n    <description>企业微信会议管理技能, 支持取消会议和更新会议受邀成员. 当用户需要&quot;取消会议&quot;, &quot;删除会议&quot;, &quot;修改会议成员&quot;, &quot;添加会议参与人&quot;, &quot;移除会议成员&quot;时触发.</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-meeting-manage/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-meeting-query</name>\n    <description>企业微信会议查询技能, 支持查询会议列表, 获取会议详情, 按关键词查找会议. 当用户需要&quot;查看会议&quot;, &quot;查询会议列表&quot;, &quot;会议详情&quot;, &quot;什么时候开会&quot;, &quot;有哪些会议&quot;, &quot;查找会议&quot;时触发.</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-meeting-query/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-msg</name>\n    <description>企业微信消息技能。提供会话列表查询、消息记录拉取（支持文本/图片/文件/语音/视频）、多媒体文件获取和文本消息发送能力。当用户需要&quot;查看消息&quot;、&quot;看聊天记录&quot;、&quot;发消息给某人&quot;、&quot;最近有什么消息&quot;、&quot;给群里发消息&quot;、&quot;看看发了什么图片/文件&quot;时触发。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-msg/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-preflight</name>\n    <description>企业微信插件前置条件检查。在执行任何 wecom_mcp 操作前，通过 shell 命令检查工具权限配置（profile 和白名单），若缺失则自动修复并提示用户重启 Gateway。所有使用 wecom_mcp 的技能都应在首次调用前执行此检查。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-preflight/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-schedule</name>\n    <description>企业微信日程管理技能。适用于用户对企业微信日程的各类管理需求。当用户需要：(1) 查询指定时间范围内的日程列表或获取日程详细信息（标题、时间、地点、参与者等），(2) 创建新日程并设置提醒、参与人等，(3) 修改已有日程的标题、时间、地点等信息或取消日程，(4) 添加或移除日程参与人，(5) 查询多个成员的闲忙状态并分析共同空闲时段以安排会议时使用此技能。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-schedule/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-smartsheet-data</name>\n    <description>企业微信智能表格数据（记录）管理技能。提供智能表格记录的增删改查能力。适用场景：(1) 查询子表全部记录 (2) 添加一行或多行记录 (3) 更新已有记录 (4) 删除记录。当用户需要读取表格数据、写入新数据、修改或删除表格行时触发此 Skill。支持通过 docid 或文档 URL 定位文档。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-data/SKILL.md</location>\n  </skill>\n  <skill>\n    <name>wecom-smartsheet-schema</name>\n    <description>企业微信智能表格结构管理技能。提供子表（Sheet）和字段（Field/列）的增删改查能力。适用场景：(1) 查询智能表格的子表列表 (2) 添加、更新、删除子表 (3) 查询子表的字段/列信息 (4) 添加、更新、删除字段/列。当用户需要管理智能表格的表结构、列定义、子表配置时触发此 Skill。支持通过 docid 或文档 URL 定位文档。</description>\n    <location>/workspace/projects/extensions/wecom-openclaw-plugin/skills/wecom-smartsheet-schema/SKILL.md</location>\n  </skill>\n</available_skills>","systemPromptReport":{"source":"run","generatedAt":1777108744477,"sessionId":"0b7ad604-85d8-4c9d-9a46-c37bf44d0fdb","sessionKey":"agent:main:main","provider":"coze","model":"auto","workspaceDir":"/workspace/projects/workspace","bootstrapMaxChars":12000,"bootstrapTotalMaxChars":600