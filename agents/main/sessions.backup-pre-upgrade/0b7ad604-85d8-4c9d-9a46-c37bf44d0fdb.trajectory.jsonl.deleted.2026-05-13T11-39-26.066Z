[0m\n[0;36m║[0m  [1m⏰ OpenClaw 定时巡检管理器[0m                       [0;36m║[0m\n[0;36m║[0m  自动化安全巡检，守护系统安全[0m                       [0;36m║[0m\n[0;36m╚════════════════════════════════════════════════════════╝[0m\n\n\n\\033[0;36m╔════════════════════════════════════════════════════════╗\\033[0m\n\\033[0;36m║\\033[0m  \\033[1m⏰ OpenClaw 定时巡检管理器\\033[0m                         \\033[0;36m║\\033[0m\n\\033[0;36m╚════════════════════════════════════════════════════════╝\\033[0m\n\n\\033[1m用法:\\033[0m\n  bash scripts/cron-manager.sh --cron <表达式或操作> [选项]\n\n\\033[1m定时任务操作:\\033[0m\n  --cron \"0 2 * * *\"     设置每日凌晨 2:00 巡检\n  --cron list            查看已配置的巡检任务\n  --cron remove          删除巡检定时任务\n  --cron status          查看巡检状态\n\n\\033[1m巡检选项:\\033[0m\n  --notify               巡检完成后发送飞书通知\n  --summary              生成并显示摘要报告\n\n\\033[1m示例:\\033[0m\n  # 设置每日巡检\n  bash scripts/cron-manager.sh --cron \"0 2 * * *\"\n\n  # 设置每4小时巡检并启用飞书通知\n  bash scripts/cron-manager.sh --cron \"0 */4 * * *\" --notify\n\n  # 查看已配置的任务\n  bash scripts/cron-manager.sh --cron list\n\n  # 删除定时任务\n  bash scripts/cron-manager.sh --cron remove\n\n  # 交互式设置（无参数）\n  bash scripts/cron-manager.sh --cron\n\n\\033[1m常用 Cron 表达式:\\033[0m\n  0 2 * * *       每天凌晨 2:00\n  0 */4 * * *     每 4 小时\n  0 9 * * 1-5     工作日 9:00\n  0 2 * * 0       每周日 2:00"}],"details":{"status":"completed","exitCode":0,"durationMs":13,"aggregated":"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n【验证4】cron-manager.sh --help\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n[0;36m╔════════════════════════════════════════════════════════╗[0m\n[0;36m║[0m  [1m⏰ OpenClaw 定时巡检管理器[0m                       [0;36m║[0m\n[0;36m║[0m  自动化安全巡检，守护系统安全[0m                       [0;36m║[0m\n[0;36m╚════════════════════════════════════════════════════════╝[0m\n\n\n\\033[0;36m╔════════════════════════════════════════════════════════╗\\033[0m\n\\033[0;36m║\\033[0m  \\033[1m⏰ OpenClaw 定时巡检管理器\\033[0m                         \\033[0;36m║\\033[0m\n\\033[0;36m╚════════════════════