train_data) * 5 / 10\n  77         for ball in range(1, 36):\n- 78             tail = ball % 10\n- 79             tail_count = sum(stats['front_count'][b] for b in range(1, 36) if b % 10 == tail)\n- 80             if tail_count >= avg_per_tail * 1.5:\n+ 66             m = front_missing[ball]\n+ 67             c = front_count[ball]\n+ 68             if m >= total * 0.8 and c < front_avg * 0.5 and m > 3:\n  81                 killed_front.add(ball)\n  82         \n- 83         # 4. 断区杀号\n+ 71         for ball in range(1, 13):\n+ 72             m = back_missing[ball]\n+ 73             c = back_count[ball]\n+ 74             if m >= total * 0.8 and c < 1.5 and m > 2:\n+ 75                 killed_back.add(ball)\n+ 76         \n+ 77         # 2. 断区杀号\n  84         zones = stats['zones']\n- 85         for zone_id, balls in zones.items():\n- 86             if len(balls) < len(train_data) * 0.05:\n- 87                 for ball in range((zone_id-1)*5+1, zone_id*5+1):\n- 88                     if 1 <= ball <= 35:\n+ 79         for zone_id in range(1, 8):\n+ 80             balls_in_zone = zones.get(zone_id, [])\n+ 81             density = len(balls_in_zone) / total if total > 0 else 0\n+ 82             if density < 0.03:\n+ 83                 zone_start = (zone_id - 1) * 5 + 1\n+ 84                 zone_end = zone_id * 5 + 1\n+ 85                 has_recent = any(zone_start <= b < zone_end for b in latest['front'])\n+ 86                 if not has_recent:\n+ 87                     for ball in range(zone_start, min(zone_end, 36)):\n  89                         killed_front.add(ball)\n  90         \n- 91         # 5. 加减法\n- 92         for i in range(len(front) - 1):\n- 93             diff = front[i+1] - front[i]\n- 94             if 1 <= diff <= 35:\n- 95                 killed_front.add(diff)\n- 96         for ball in front:\n- 97             new_ball = ball + 3\n- 98             if new_ball > 35:\n- 99                 new_ball -= 35\n-100             killed_front.add(new_ball)\n-101         \n-102         # 6. 公式杀号\n+ 90         # 3. 简化公式杀号\n 103         A1, A2, A3, A4, A5 = front[0], front[1], front[2], front[3], front[4]\n 104         B = A5 - A3 - A1\n 105         if B < 0:\n 106             B = abs(B)\n-107         for b in [B, B+1, B+3]:\n-108             if 1 <= b <= 35:\n+ 95         for b in [B, B+1]:\n+ 96             if 1 <= b <= 35 and (front_missing[b] > total * 0.3 or front_count[b] < 3):\n 109                 killed_front.add(b)\n-110         C = A4 - A2\n-111         for c in [C, C+10, C-10]:\n-112             if 1 <= c <= 35:\n-113                 killed_front.add(c)\n 114         \n-115         # 7. 首尾联动\n+ 99         for diff in [A5-A1, A3-A1, A5-A3]:\n+100             if 1 <= diff <= 35 and (front_missing[diff] > total * 0.4 or front_count[diff] < 3):\n+101                 killed_front.add(diff)\n+102         \n+103         # 4. 首尾联动\n 116         kill_ball = (min(front) + max(back)) % 35\n 117         if kill_ball == 0:\n 118             kill_ball = 35\n-119         killed_front.add(kill_ball)\n+107         if front_missing[kill_ball] > total * 0.3:\n+108             killed_front.add(kill_ball)\n 120         \n-121         # 8. 和值杀号（简化）\n+110         # 5. 和值杀号（极端情况）\n 122         recent_sums = dm.get_recent_sums(train_data, 10)\n 123         if recent_sums:\n 124             avg_sum = sum(recent_sums) / len(recent_sums)\n 125             latest_sum = sum(front)\n-126             if latest_sum > avg_sum + 10:\n-127                 for ball in range(28, 36):\n-128                     killed_front.add(ball)\n+115             if abs(latest_sum - avg_sum) / avg_sum > 0.25:\n+116                 if latest_sum > avg_sum * 1.25:\n+117                     for ball in range(30, 36):\n+118                         killed_front.add(ball)\n 129         \n 130         # 清理\n 131         killed_front = {b for b in killed_front if 1 <= b <= 35}\n 132         killed_back = {b for b in killed_back if 1 <= b <= 12}\n     ...\n 134         # 统计结果\n 135         actual_front = set(test_record['front'])\n 136         actual_back = set(test_record['back'])\n 137         \n-138         # 杀号命中率：被杀的号码中有多少是实际开奖号码\n 139         front_hit = killed_front & actual_front\n 140         back_hit = killed_back & actual_back\n 141         \n-142         # 杀号准确率：杀的号码中有多少确实没中\n 143         front_accuracy = (len(killed_front) - len(front_hit)) / max(len(killed_front), 1)\n 144         back_accuracy = (len(killed_back) - len(back_hit)) / max(len(killed_back), 1)\n 145         \n 146         return {\n     ...","firstChangedLine":45},"isError":false,"timestamp":1778413889793}}
