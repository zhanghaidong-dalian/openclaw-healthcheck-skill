   back_avg = sum(back_count.values()) / 12\n        for ball in range(1, 13):\n            m = back_missing[ball]\n            c = stats['back_count'][ball]\n            back_avg = sum(stats['back_count'].values()) / 12\n            if m >= total * 0.7 and m > 3 and c < back_avg and c >= 1:\n                killed_back.add(ball)\n        \n        # 2. 断区杀号：密度<5% 且 上期无出号 且 全部低频\n        for zone_id in range(1, 8):\n            balls_in_zone = zones.get(zone_id, [])\n            density = len(balls_in_zone) / total if total > 0 else 0\n            if density < 0.05:\n                zone_start = (zone_id - 1) * 5 + 1\n                zone_end = zone_id * 5 + 1\n                has_recent = any(zone_start <= b < zone_end for b in latest['front'])\n                if not has_recent:\n                    all_low_freq = all(front_count.get(b, 0) < front_avg for b in range(zone_start, min(zone_end, 36)))\n                    if all_low_freq:\n                        for ball in range(zone_start, min(zone_end, 36)):\n                            killed_front.add(ball)\n        \n        # 4. 公式杀号\n        A1, A2, A3, A4, A5 = front[0], front[1], front[2], front[3], front[4]\n        B = A5 - A3 - A1\n        if B < 0:\n            B = abs(B)\n        if B > 0:\n            killed_front.add(B)\n        diff1 = A5 - A1\n        if 1 <= diff1 <= 35:\n            killed_front.add(diff1)\n        # 验证遗漏\n        final_killed = {b for b in killed_front if front_missing[b] > total * 0.4}\n        killed_front = final_killed\n        \n        # 5. 首尾联动\n        kill_ball = (min(front) + max(back)) % 35\n        if kill_ball == 0:\n            kill_ball = 35\n        if front_missing[kill_ball] > total * 0.5:\n            killed_front.add(kill_ball)"}],"path":"/workspace/projects/workspace/skills/super-lotto-killer/killer/backtest.py"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":285,"output":1123,"cacheRead":137083,"cacheWrite":0,"totalTokens":13