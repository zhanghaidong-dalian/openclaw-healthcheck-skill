{"type":"message","id":"6b460118","parentId":"02fc344f","timestamp":"2026-05-06T13:24:19.224Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建爬虫脚本，使用 playwright 直接抓取数据。","thinkingSignature":"reasoning_content"},{"type":"text","text":"现在创建爬虫脚本："},{"type":"toolCall","id":"call_1174d3e2473048b1aac12d0d","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n大乐透历史数据爬虫脚本\n使用 Playwright 抓取彩票500万网站数据\n\"\"\"\n\nimport sqlite3\nimport json\nimport time\nfrom pathlib import Path\nfrom datetime import datetime\nfrom playwright.sync_api import sync_playwright\n\n# 数据库路径\nDB_PATH = Path(__file__).parent.parent / \"data\" / \"super_lotto.db\"\n\n# 数据源配置\nBASE_URL = \"https://datachart.500.com/dlt/history/newinc/history.php\"\n\ndef parse_table_data(page):\n    \"\"\"解析表格数据\"\"\"\n    records = []\n    \n    # 获取表格中的所有行\n    rows = page.query_selector_all('tbody tr')\n    \n    for row in rows:\n        try:\n            cells = row.query_selector_all('td')\n            if len(cells) < 15:  # 数据行应该有足够的列\n                continue\n            \n            # 提取数据\n            issue_number = cells[0].inner_text().strip()\n            \n            # 前区（红球）- 5个号码\n            front_balls = []\n            for i in range(1, 6):\n                ball = int(cells[i].inner_text().strip())\n                front_balls.append(ball)\n            \n            # 后区（蓝球）- 2个号码\n            back_balls = []\n            for i in range(6, 8):\n                ball = int(cells[i].inner_text().strip())\n                back_balls.append(ball)\n            \n            # 开奖日期\n            draw_date_str = cells[-1].inner_text().strip()\n            draw_date = datetime.strptime(draw_date_str, '%Y-%m-%d').date()\n            \n            # 奖池金额和销售金额（可选）\n            pool_amount_str = cells[8].inner_text().strip().replace(',', '')\n            sales_amount_str = cells[13].inner_text().strip().replace(',', '')\n            \n            try:\n                pool_amount = int(pool_amount_str) if pool_amount_str else None\n                sales_amount = int(sales_amount_str) if sales_amount_str else None\n            except:\n                pool_amount = None\n                sales_amount = None\n            \n            records.append({\n                'issue_number': issue_number,\n                'draw_date': draw_date,\n                'front_balls': front_balls,\n                'back_balls': back_balls,\n                'pool_amount': pool_amount,\n                'sales_amount': sales_amount\n            })\n            \n        except Exception as e:\n            print(f\"⚠️ 解析行失败: {e}\")\n            continue\n    \n    return records\n\n\ndef fetch_all_history():\n    \"\"\"抓取全部历史数据\"\"\"\n    print(\"=\" * 60)\n    print(\"🎲 大乐透历史数据抓取\")\n    print(\"=\" * 60)\n    \n    all_records = []\n    \n    with sync_playwright() as p:\n        # 启动浏览器\n        browser = p.chromium.launch(headless=True)\n        page = browser.new_page()\n        \n        try:\n            # 访问页面\n            print(f\"\\n📡 正在访问彩票500万网...\")\n            page.goto(BASE_URL, wait_until='networkidle')\n            \n            # 等待数据加载\n            page.wait_for_selector('tbody tr', timeout=10000)\n            time.sleep(1)\n            \n            # 先尝试点击\"最近100期\"按钮\n            try:\n                print(\"📄 点击查看最近100期...\")\n                page.click('text=最近100期')\n                page.wait_for_load_state('networkidle')\n                time.sleep(1)\n            except:\n                print(\"⚠️ 未找到\\\"最近100期\\\"按钮，使用默认数据\")\n            \n            # 解析当前页数据\n            print(\"📊 正在解析数据...\")\n            records = parse_table_data(page)\n            \n            if records:\n                all_records.extend(records)\n                print(f\"✅ 成功抓取 {len(records)} 条记录\")\n            else:\n                print(\"❌ 未抓取到数据\")\n            \n        except Exception as e:\n            print(f\"❌ 抓取失败: {e}\")\n        finally:\n            browser.close()\n    \n    # 保存到数据库\n    if all_records:\n        saved = save_to_database(all_records)\n        print(f\"\\n✅ 总计保存 {saved} 条记录\")\n        return saved\n    \n    return 0\n\n\ndef save_to_database(records):\n    \"\"\"保存数据到数据库\"\"\"\n    if not records:\n        print(\"⚠️ 没有数据需要保存\")\n        return 0\n    \n    if not DB_PATH.exists():\n        print(\"❌ 数据库文件不存在，请先运行 init_db.py\")\n        return 0\n    \n    conn = sqlite3.connect(DB_PATH)\n    cursor = conn.cursor()\n    \n    inserted = 0\n    updated = 0\n    \n    for record in records:\n        try:\n            # 检查是否已存在\n            cursor.execute(\n                'SELECT id FROM lottery_records WHERE issue_number = ?',\n                (record['issue_number'],)\n            )\n            \n            if cursor.fetchone():\n                # 更新已有记录\n                cursor.execute('''\n                    UPDATE lottery_records SET\n                        draw_date = ?,\n                        front_ball_1 = ?,\n                        front_ball_2 = ?,\n                        front_ball_3 = ?,\n                        front_ball_4 = ?,\n                        front_ball_5 = ?,\n                        back_ball_1 = ?,\n                        back_ball_2 = ?,\n                        pool_amount = ?,\n                        sales_amount = ?,\n                        updated_at = CURRENT_TIMESTAMP\n                    WHERE issue_number = ?\n                ''', (\n                    record['draw_date'],\n                    record['front_balls'][0],\n                    record['front_balls'][1],\n                    record['front_balls'][2],\n                    record['front_balls'][3],\n                    record['front_balls'][4],\n                    record['back_balls'][0],\n                    record['back_balls'][1],\n                    record['pool_amount'],\n                    record['sales_amount'],\n                    record['issue_number']\n                ))\n                updated += 1\n            else:\n                # 插入新记录\n                cursor.execute('''\n                    INSERT INTO lottery_records (\n                        issue_number, draw_date,\n                        front_ball_1, front_ball_2, front_ball_3,\n                        front_ball_4, front_ball_5,\n                        back_ball_1, back_ball_2,\n                        pool_amount, sales_amount\n                    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n                ''', (\n                    record['issue_number'],\n                    record['draw_date'],\n                    record['front_balls'][0],\n                    record['front_balls'][1],\n                    record['front_balls'][2],\n                    record['front_balls'][3],\n                    record['front_balls'][4],\n                    record['back_balls'][0],\n                    record['back_balls'][1],\n                    record['pool_amount'],\n                    record['sales_amount']\n                ))\n                inserted += 1\n                \n        except Exception as e:\n            print(f\"⚠️ 保存记录失败 {record['issue_number']}: {e}\")\n            continue\n    \n    conn.commit()\n    conn.close()\n    \n    print(f\"✅ 数据保存完成: 新增 {inserted} 条, 更新 {updated} 条\")\n    return inserted + updated\n\n\nif __name__ == \"__main__\":\n    # 检查数据库是否存在\n    if not DB_PATH.exists():\n        print(\"⚠️ 数据库未初始化，正在初始化...\")\n        import init_db\n        init_db.init_database()\n    \n    fetch_all_history()\n","path":"/workspace/projects/workspace/skills/super-lotto/scripts/fetch_history.py"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":639,"output":1622,"cacheRead":83904,"cacheWrite":0,"totalTokens":86165,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778073820295,"responseId":"20260506212340f8a78527a8be43c8"}}
