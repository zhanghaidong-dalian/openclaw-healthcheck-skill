enclaw/skills/skill-creator","source":"openclaw-bundled","sourceInfo":{"baseDir":"/usr/lib/node_modules/openclaw/skills/skill-creator","origin":"top-level","path":"/usr/lib/node_modules/openclaw/skills/skill-creator/SKILL.md","scope":"project","source":"openclaw-bundled"},"disableModelInvocation":false,"available":true},{"id":"skillhub-preference","name":"skillhub-preference","description":"Prefer `skillhub` for skill discovery/install/update, then fallback to `clawhub` when unavailable or no match. Use when users ask about skills, 插件, or capability extension.","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/skillhub-preference/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"super-lotto","name":"super-lotto","description":"大乐透历史数据抓取、存储和分析技能。用于查询彩票500万网站、抓取历史开奖数据（前区红球+后区蓝球）、存储到本地数据库、进行数据分析和频率统计、生成号码预测。触发词：大乐透、彩票、开奖、彩票预测、历史数据、中奖号码、彩票分析、超级大乐透、大乐透预测。","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/super-lotto/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/super-lotto","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/super-lotto","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/super-lotto/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"super-lotto-killer","name":"super-lotto-killer","description":"大乐透杀号选球技能。实现8种杀号规则（冷热、遗漏、尾数、断区、加减法、公式、首尾联动、和值），基于历史数据统计分析，过滤低概率号码，生成精选预测组合，支持回测验证。触发词：大乐透杀号、大乐透选球、杀号选号。","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/super-lotto-killer/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/super-lotto-killer","source":"openclaw-workspace","sourceInfo":{"baseD