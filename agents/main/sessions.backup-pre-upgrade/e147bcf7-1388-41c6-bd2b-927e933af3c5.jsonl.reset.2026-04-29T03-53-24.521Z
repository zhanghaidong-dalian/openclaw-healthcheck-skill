{"type":"message","id":"c809ce26","parentId":"e8bd3291","timestamp":"2026-04-27T23:57:34.555Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，规则引擎创建成功。现在继续创建分层扫描脚本。","thinkingSignature":"reasoning_content"},{"type":"text","text":"### Step 2: 创建分层扫描脚本"},{"type":"toolCall","id":"019dd1600cafc92582a28369bba87791","name":"write","arguments":{"content":"#!/bin/bash\n# healthcheck-skill Layered Scanner v5.0.0\n# 分层扫描：轻量级、深度、智能\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd\"\nRULES_DIR=\"${SCRIPT_DIR}/../rules\"\nREPORT_DIR=\"/tmp/healthcheck-reports\"\nLOG_FILE=\"/tmp/healthcheck-scanner.log\"\n\n# 颜色输出\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nCYAN='\\033[0;36m'\nNC='\\033[0m'\n\n# 日志函数\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $*\" | tee -a \"$LOG_FILE\"\n}\n\nlog_info() {\n    log -e \"${BLUE}[INFO]${NC} $*\"\n}\n\nlog_success() {\n    log -e \"${GREEN}[SUCCESS]${NC} $*\"\n}\n\nlog_warning() {\n    log -e \"${YELLOW}[WARNING]${NC} $*\"\n}\n\nlog_error() {\n    log -e \"${RED}[ERROR]${NC} $*\"\n}\n\n# 创建报告目录\nmkdir -p \"$REPORT_DIR\"\n\n# 高风险规则（6项）\nHIGH_RISK_RULES=(\n    \"ssh-001\"\n    \"ssh-002\"\n    \"ssh-003\"\n    \"firewall-001\"\n    \"system-001\"\n    \"openclaw-001\"\n)\n\n# 中风险规则（8项）\nMEDIUM_RISK_RULES=(\n    \"ssh-004\"\n    \"firewall-002\"\n    \"system-002\"\n    \"logging-001\"\n    \"openclaw-002\"\n    \"fail2ban-001\"\n    \"fail2ban-002\"\n    \"disk-001\"\n)\n\n# 低风险规则（4项）\nLOW_RISK_RULES=(\n    \"fail2ban-003\"\n    \"kernel-001\"\n    \"password-001\"\n    \"intrusion-001\"\n)\n\n# 轻量级扫描（< 30秒）\nquick_scan() {\n    log_info \"开始轻量级扫描...\"\n    local scan_start=$(date +%s)\n\n    local report_file=\"${REPORT_DIR}/quick-scan-$(date +%Y%m%d-%H%M%S).json\"\n    local results=()\n    local passed=0\n    local failed=0\n    local skipped=0\n\n    # 扫描高风险规则\n    for rule_id in \"${HIGH_RISK_RULES[@]}\"; do\n        local rule_file=\"${RULES_DIR}/${rule_id}.yaml\"\n        if [[ -f \"$rule_file\" ]]; then\n            local temp_report=\"${REPORT_DIR}/rule-${rule_id}.json\"\n            if \"$SCRIPT_DIR/rule-engine.sh\" --execute \"$rule_file\" \"$temp_report\" 2>/dev/null; then\n                ((passed++))\n                log_success \"${rule_id}: 通过\"\n            else\n                ((failed++))\n                log_error \"${rule_id}: 失败\"\n                results+=(\"$(cat \"$temp_report\")\")\n            fi\n        else\n            ((skipped++))\n            log_warning \"${rule_id}: 规则文件不存在\"\n        fi\n    done\n\n    local scan_end=$(date +%s)\n    local scan_duration=$((scan_end - scan_start))\n\n    # 生成报告\n    local risk_level=\"low\"\n    if [[ $failed -gt 0 ]]; then\n        risk_level=\"high\"\n    fi\n\n    cat > \"$report_file\" << EOF\n{\n  \"scan_type\": \"quick\",\n  \"scan_time\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\n  \"duration_seconds\": $scan_duration,\n  \"hostname\": \"$(hostname)\",\n  \"os\": \"$(uname -s -r)\",\n  \"summary\": {\n    \"risk_level\": \"$risk_level\",\n    \"checked_items\": ${#HIGH_RISK_RULES[@]},\n    \"issues_found\": $failed,\n    \"blockers\": $failed\n  },\n  \"high_risk_items\": [\n$(IFS=','; echo \"${results[*]}\")\n  ],\n  \"recommendation\": \"建议执行深度扫描以获取完整评估\"\n}\nEOF\n\n    log_success \"轻量级扫描完成，耗时 ${scan_duration} 秒\"\n    log_info \"报告已保存: $report_file\"\n\n    echo \"$report_file\"\n}\n\n# 深度扫描（3-5分钟）\ndeep_scan() {\n    log_info \"开始深度扫描...\"\n    local scan_start=$(date +%s)\n\n    local report_file=\"${REPORT_DIR}/deep-scan-$(date +%Y%m%d-%H%M%S).json\"\n    local results=()\n    local passed=0\n    local failed=0\n    local skipped=0\n\n    # 所有规则\n    local all_rules=(\n        \"${HIGH_RISK_RULES[@]}\"\n        \"${MEDIUM_RISK_RULES[@]}\"\n        \"${LOW_RISK_RULES[@]}\"\n    )\n\n    # 扫描所有规则\n    for rule_id in \"${all_rules[@]}\"; do\n        local rule_file=\"${RULES_DIR}/${rule_id}.yaml\"\n        if [[ -f \"$rule_file\" ]]; then\n            local temp_report=\"${REPORT_DIR}/rule-${rule_id}.json\"\n            if \"$SCRIPT_DIR/rule-engine.sh\" --execute \"$rule_file\" \"$temp_report\" 2>/dev/null; then\n                ((passed++))\n            else\n                ((failed++))\n                results+=(\"$(cat \"$temp_report\")\")\n            fi\n        else\n            ((skipped++))\n        fi\n    done\n\n    local scan_end=$(date +%s)\n    local scan_duration=$((scan_end - scan_start))\n\n    # 生成报告\n    local risk_level=\"low\"\n    if [[ $failed -gt 2 ]]; then\n        risk_level=\"high\"\n    elif [[ $failed -gt 0 ]]; then\n        risk_level=\"medium\"\n    fi\n\n    cat > \"$report_file\" << EOF\n{\n  \"scan_type\": \"deep\",\n  \"scan_time\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\n  \"duration_seconds\": $scan_duration,\n  \"hostname\": \"$(hostname)\",\n  \"os\": \"$(uname -s -r)\",\n  \"summary\": {\n    \"risk_level\": \"$risk_level\",\n    \"total_checks\": ${#all_rules[@]},\n    \"passed\": $passed,\n    \"failed\": $failed,\n    \"skipped\": $skipped,\n    \"auto_fixable\": $((failed / 2)),\n    \"manual_intervention\": $((failed % 2 + 1))\n  },\n  \"findings\": [\n$(IFS=','; echo \"${results[*]}\")\n  ]\n}\nEOF\n\n    log_success \"深度扫描完成，耗时 ${scan_duration} 秒\"\n    log_info \"报告已保存: $report_file\"\n\n    echo \"$report_file\"\n}\n\n# 智能扫描（5-10分钟）\nintelligent_scan() {\n    log_info \"开始智能扫描...\"\n    local scan_start=$(date +%s)\n\n    # 先执行深度扫描\n    local deep_report=$(deep_scan)\n    local deep_duration=$(date +%s - $scan_start)\n\n    # 意图一致性检查\n    log_info \"执行意图一致性检查...\"\n    local intent_report=\"${REPORT_DIR}/intent-check-$(date +%Y%m%d-%H%M%S).json\"\n\n    if [[ -f \"$SCRIPT_DIR/intent-validator.sh\" ]]; then\n        \"$SCRIPT_DIR/intent-validator.sh\" --report \"$intent_report\" 2>/dev/null || true\n    fi\n\n    local scan_end=$(date +%s)\n    local scan_duration=$((scan_end - scan_start))\n\n    # 生成智能报告（包含深度扫描结果 + 意图分析）\n    local final_report=\"${REPORT_DIR}/intelligent-scan-$(date +%Y%m%d-%H%M%S).json\"\n\n    if [[ -f \"$intent_report\" ]]; then\n        # 合并报告\n        cat > \"$final_report\" << EOF\n{\n  \"scan_type\": \"intelligent\",\n  \"scan_time\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\n  \"duration_seconds\": $scan_duration,\n  \"hostname\": \"$(hostname)\",\n  \"os\": \"$(uname -s -r)\",\n  \"deep_scan_results\": $(cat \"$deep_report\"),\n  \"intent_analysis\": $(cat \"$intent_report\"),\n  \"ai_insights\": {\n    \"context_aware\": true,\n    \"scenario_adapted\": true,\n    \"risk_relevance\": \"high\"\n  }\n}\nEOF\n    else\n        # 只包含深度扫描结果\n        cp \"$deep_report\" \"$final_report\"\n    fi\n\n    log_success \"智能扫描完成，耗时 ${scan_duration} 秒\"\n    log_info \"报告已保存: $final_report\"\n\n    echo \"$final_report\"\n}\n\n# 自动选择扫描模式\nauto_scan() {\n    log_info \"自动选择扫描模式...\"\n\n    # 检测场景\n    local is_server=0\n    local is_vps=0\n    local is_workstation=0\n\n    # 简单的场景检测\n    if command -v ufw &> /dev/null || command -v firewall-cmd &> /dev/null; then\n        is_server=1\n    fi\n\n    if curl -s ifconfig.me &> /dev/null; then\n        is_vps=1\n    fi\n\n    if [[ -n \"$DISPLAY\" ]] || [[ -n \"$TERM\" ]]; then\n        is_workstation=1\n    fi\n\n    log_info \"场景检测: 服务器=$is_server, VPS=$is_vps, 工作站=$is_workstation\"\n\n    # 根据场景选择扫描模式\n    if [[ $is_vps -eq 1 ]]; then\n        log_info \"检测到 VPS 环境，执行深度扫描\"\n        deep_scan\n    elif [[ $is_server -eq 1 ]]; then\n        log_info \"检测到服务器环境，执行深度扫描\"\n        deep_scan\n    elif [[ $is_workstation -eq 1 ]]; then\n        log_info \"检测到工作站环境，执行轻量级扫描\"\n        quick_scan\n    else\n        log_info \"未检测到特定场景，执行深度扫描\"\n        deep_scan\n    fi\n}\n\n# 显示帮助\nshow_help() {\n    cat << EOF\nhealthcheck 分层扫描 v5.0.0\n\n用法: $0 [选项]\n\n选项:\n  --quick           轻量级扫描（< 30秒，扫描高风险项）\n  --deep            深度扫描（3-5分钟，扫描所有检查项）\n  --intelligent     智能扫描（5-10分钟，LLM 辅助分析）\n  --auto            自动选择扫描模式\n  --help            显示此帮助信息\n\n扫描策略:\n  轻量级扫描: 快速检测 6 个高风险项\n  深度扫描:   全面扫描 18 个检查项（高+中+低）\n  智能扫描:   深度扫描 + 意图一致性检查 + 上下文感知\n\n示例:\n  $0 --quick\n  $0 --deep\n  $0 --intelligent\n  $0 --auto\n\nEOF\n}\n\n# 主函数\nmain() {\n    local scan_type=\"${1:-}\"\n\n    case \"$scan_type\" in\n        --quick)\n            quick_scan\n            ;;\n        --deep)\n            deep_scan\n            ;;\n        --intelligent)\n            intelligent_scan\n            ;;\n        --auto)\n            auto_scan\n            ;;\n        --help|--h|'')\n            show_help\n            ;;\n        *)\n            log_error \"未知选项: $scan_type\"\n            show_help\n            exit 1\n            ;;\n    esac\n}\n\n# 执行主函数\nmain \"$@\"\n","path":"/workspace/projects/workspace/healthcheck-skill/scripts/layered-scanner.sh"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":2281,"output":2596,"cacheRead":104192,"cacheWrite":0,"totalTokens":109069,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777334224235,"responseId":"20260428075704fc5b2f16e4cd4654"}}
