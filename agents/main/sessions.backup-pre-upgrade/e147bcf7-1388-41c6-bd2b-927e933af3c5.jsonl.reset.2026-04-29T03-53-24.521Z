{"type":"message","id":"73fc16bb","parentId":"747384bb","timestamp":"2026-04-27T23:59:19.962Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建白名单管理器。","thinkingSignature":"reasoning_content"},{"type":"text","text":"### Step 6: 创建白名单管理器"},{"type":"toolCall","id":"019dd161a7b2c82c3a316ba036d5d9ae","name":"write","arguments":{"content":"#!/bin/bash\n# healthcheck-skill Whitelist Manager v5.0.0\n# 白名单管理：域名、路径、服务\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd\"\nCONFIG_DIR=\"${SCRIPT_DIR}/../config\"\nWHITELIST_FILE=\"${CONFIG_DIR}/whitelist.yaml\"\nLOG_FILE=\"/tmp/healthcheck-whitelist.log\"\n\n# 颜色输出\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m'\n\n# 日志函数\nlog() {\n    echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $*\" | tee -a \"$LOG_FILE\"\n}\n\nlog_info() {\n    log -e \"${BLUE}[INFO]${NC} $*\"\n}\n\nlog_success() {\n    log -e \"${GREEN}[SUCCESS]${NC} $*\"\n}\n\nlog_warning() {\n    log -e \"${YELLOW}[WARNING]${NC} $*\"\n}\n\nlog_error() {\n    log -e \"${RED}[ERROR]${NC} $*\"\n}\n\n# 创建配置目录\nmkdir -p \"$CONFIG_DIR\"\n\n# 初始化白名单文件\ninit_whitelist() {\n    log_info \"初始化白名单文件...\"\n\n    if [[ ! -f \"$WHITELIST_FILE\" ]]; then\n        cat > \"$WHITELIST_FILE\" << 'EOF'\n---\n# healthcheck-skill 白名单配置\n\nwhitelist:\n  # 信任域名（用于网络访问）\n  domains:\n    - \"github.com\"\n    - \"api.github.com\"\n    - \"raw.githubusercontent.com\"\n    - \"update.ubuntu.com\"\n    - \"archive.ubuntu.com\"\n    - \"security.ubuntu.com\"\n    - \"xiaping.coze.site\"\n    - \"*.xiaping.coze.site\"\n  reason: \"系统更新、规则获取和平台访问\"\n\n  # 信任路径（用于文件访问）\n  paths:\n    - \"/etc/ssh/sshd_config\"\n    - \"/etc/ssh/ssh_config\"\n    - \"/etc/ufw/\"\n    - \"/etc/fail2ban/\"\n    - \"/var/log/openclaw/\"\n    - \"/var/log/healthcheck/\"\n    - \"~/.openclaw/\"\n  reason: \"配置文件和日志目录\"\n\n  # 信任服务（用于服务重启）\n  services:\n    - name: \"sshd\"\n      restart_required: true\n      reason: \"SSH 服务需要重启以应用安全配置\"\n    - name: \"ufw\"\n      restart_required: true\n      reason: \"防火墙服务需要重启以应用规则\"\n    - name: \"fail2ban\"\n      restart_required: true\n      reason: \"fail2ban 需要重启以应用新规则\"\n    - name: \"cron\"\n      restart_required: false\n      reason: \"定时任务服务\"\n\n  # 自定义白名单（用户可扩展）\n  custom:\n    domains: []\n    paths: []\n    services: []\n    commands: []\n\n# 白名单规则\nrules:\n  # 域名访问规则\n  domain_access:\n    allow_whitelisted: true\n    block_non_whitelisted: false\n    require_declaration: true\n\n  # 路径访问规则\n  path_access:\n    allow_whitelisted: true\n    block_non_whitelisted: false\n    require_declaration: true\n\n  # 服务操作规则\n  service_operations:\n    allow_whitelisted: true\n    require_confirmation: true\n    require_declaration: true\nEOF\n        log_success \"白名单文件已创建: $WHITELIST_FILE\"\n    else\n        log_info \"白名单文件已存在: $WHITELIST_FILE\"\n    fi\n}\n\n# 添加域名到白名单\nadd_domain() {\n    local domain=\"$1\"\n\n    if [[ -z \"$domain\" ]]; then\n        log_error \"域名不能为空\"\n        return 1\n    fi\n\n    log_info \"添加域名到白名单: $domain\"\n\n    # 检查是否已存在\n    if yq eval \".whitelist.domains[] | select(. == \\\"$domain\\\")\" \"$WHITELIST_FILE\" &>/dev/null; then\n        log_warning \"域名已存在: $domain\"\n        return 0\n    fi\n\n    # 添加域名\n    yq eval \".whitelist.domains += \\\"$domain\\\"\" -i \"$WHITELIST_FILE\"\n    log_success \"域名已添加: $domain\"\n}\n\n# 添加路径到白名单\nadd_path() {\n    local path=\"$1\"\n\n    if [[ -z \"$path\" ]]; then\n        log_error \"路径不能为空\"\n        return 1\n    fi\n\n    log_info \"添加路径到白名单: $path\"\n\n    # 检查是否已存在\n    if yq eval \".whitelist.paths[] | select(. == \\\"$path\\\")\" \"$WHITELIST_FILE\" &>/dev/null; then\n        log_warning \"路径已存在: $path\"\n        return 0\n    fi\n\n    # 添加路径\n    yq eval \".whitelist.paths += \\\"$path\\\"\" -i \"$WHITELIST_FILE\"\n    log_success \"路径已添加: $path\"\n}\n\n# 列出所有白名单\nlist_whitelist() {\n    log_info \"列出所有白名单...\"\n\n    echo -e \"\\n${CYAN}=== 域名白名单 ===${NC}\"\n    yq eval '.whitelist.domains[]' \"$WHITELIST_FILE\" | while IFS= read -r domain; do\n        echo \"  - $domain\"\n    done\n\n    echo -e \"\\n${CYAN}=== 路径白名单 ===${NC}\"\n    yq eval '.whitelist.paths[]' \"$WHITELIST_FILE\" | while IFS= read -r path; do\n        echo \"  - $path\"\n    done\n\n    echo -e \"\\n${CYAN}=== 服务白名单 ===${NC}\"\n    yq eval '.whitelist.services[].name' \"$WHITELIST_FILE\" | while IFS= read -r service; do\n        local restart_required=$(yq eval \".whitelist.services[] | select(.name == \\\"$service\\\") | .restart_required\" \"$WHITELIST_FILE\")\n        echo \"  - $service (restart: $restart_required)\"\n    done\n}\n\n# 验证白名单\ncheck_whitelist() {\n    log_info \"验证白名单...\"\n\n    # 检查 YAML 格式\n    if command -v yq &> /dev/null; then\n        if yq eval '.' \"$WHITELIST_FILE\" > /dev/null 2>&1; then\n            log_success \"白名单文件格式正确\"\n        else\n            log_error \"白名单文件格式错误\"\n            return 1\n        fi\n    else\n        log_warning \"yq 未安装，跳过格式验证\"\n    fi\n\n    # 检查必需字段\n    local required_sections=(\"domains\" \"paths\" \"services\")\n    for section in \"${required_sections[@]}\"; do\n        if yq eval \".whitelist.$section\" \"$WHITELIST_FILE\" > /dev/null 2>&1; then\n            local count=$(yq eval \".whitelist.$section | length\" \"$WHITELIST_FILE\")\n            log_success \"$section: $count 个条目\"\n        else\n            log_error \"缺少必需部分: $section\"\n            return 1\n        fi\n    done\n\n    log_success \"白名单验证通过\"\n}\n\n# 检查项目是否在白名单中\ncheck_item() {\n    local type=\"$1\"\n    local item=\"$2\"\n\n    case \"$type\" in\n        domain)\n            if yq eval \".whitelist.domains[] | select(. == \\\"$item\\\" or (. | startswith(\\\"*\\\")))\" \"$WHITELIST_FILE\" &>/dev/null; then\n                echo \"whitelisted\"\n            else\n                echo \"not_whitelisted\"\n            fi\n            ;;\n        path)\n            if yq eval \".whitelist.paths[] | select(. == \\\"$item\\\")\" \"$WHITELIST_FILE\" &>/dev/null; then\n                echo \"whitelisted\"\n            else\n                echo \"not_whitelisted\"\n            fi\n            ;;\n        service)\n            if yq eval \".whitelist.services[].name | select(. == \\\"$item\\\")\" \"$WHITELIST_FILE\" &>/dev/null; then\n                echo \"whitelisted\"\n            else\n                echo \"not_whitelisted\"\n            fi\n            ;;\n        *)\n            log_error \"未知类型: $type\"\n            echo \"unknown\"\n            return 1\n            ;;\n    esac\n}\n\n# 导入自定义白名单\nimport_whitelist() {\n    local file=\"$1\"\n\n    if [[ ! -f \"$file\" ]]; then\n        log_error \"文件不存在: $file\"\n        return 1\n    fi\n\n    log_info \"导入自定义白名单: $file\"\n\n    # 合并自定义白名单\n    yq eval-all '. as $item ireduce ({}; . *+ $item)' \"$WHITELIST_FILE\" \"$file\" > \"${WHITELIST_FILE}.tmp\" && mv \"${WHITELIST_FILE}.tmp\" \"$WHITELIST_FILE\"\n\n    log_success \"自定义白名单已导入\"\n}\n\n# 显示帮助\nshow_help() {\n    cat << EOF\nhealthcheck 白名单管理器 v5.0.0\n\n用法: $0 [选项] [参数]\n\n选项:\n  --init                            初始化白名单文件\n  --add-domain <域名>               添加域名到白名单\n  --add-path <路径>                 添加路径到白名单\n  --list                            列出所有白名单\n  --check                           验证白名单\n  --check-item <类型> <项目>        检查项目是否在白名单中\n  --import <文件>                   导入自定义白名单\n  --help                            显示此帮助信息\n\n类型:\n  domain   - 域名\n  path     - 路径\n  service  - 服务\n\n示例:\n  $0 --init\n  $0 --add-domain example.com\n  $0 --add-path /custom/path\n  $0 --list\n  $0 --check\n  $0 --check-item domain example.com\n  $0 --import /path/to/custom-whitelist.yaml\n\nEOF\n}\n\n# 主函数\nmain() {\n    local action=\"${1:-}\"\n\n    # 确保白名单文件存在\n    if [[ \"$action\" != \"--init\" ]] && [[ ! -f \"$WHITELIST_FILE\" ]]; then\n        init_whitelist\n    fi\n\n    case \"$action\" in\n        --init)\n            init_whitelist\n            ;;\n        --add-domain)\n            shift\n            add_domain \"$1\"\n            ;;\n        --add-path)\n            shift\n            add_path \"$1\"\n            ;;\n        --list)\n            list_whitelist\n            ;;\n        --check)\n            check_whitelist\n            ;;\n        --check-item)\n            shift\n            check_item \"$@\"\n            ;;\n        --import)\n            shift\n            import_whitelist \"$1\"\n            ;;\n        --help|--h|'')\n            show_help\n            ;;\n        *)\n            log_error \"未知选项: $action\"\n            show_help\n            exit 1\n            ;;\n    esac\n}\n\n# 执行主函数\nmain \"$@\"\n","path":"/workspace/projects/workspace/healthcheck-skill/scripts/whitelist-manager.sh"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":2577,"output":2513,"cacheRead":112576,"cacheWrite":0,"totalTokens":117666,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777334329586,"responseId":"202604280758494ff8df84d322433a"}}
