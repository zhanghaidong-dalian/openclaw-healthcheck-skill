nd_services=1\n-193         fi\n-194     done < \"$(sed -n '/^whitelist:/,/^rules:/p' \"$WHITELIST_FILE\")\"\n-195     if [[ $found_services -eq 0 ]]; then\n-196         echo \"  (无)\"\n-197     fi\n+164     grep \"name:\" \"$WHITELIST_FILE\" | head -4 | awk '{print \"  - \" $2}' | tr -d '\"' || echo \"  (无)\"\n 198 }\n 199 \n 200 # 验证白名单\n 201 check_whitelist() {\n     ...","firstChangedLine":158},"isError":false,"timestamp":1777334532693}}
