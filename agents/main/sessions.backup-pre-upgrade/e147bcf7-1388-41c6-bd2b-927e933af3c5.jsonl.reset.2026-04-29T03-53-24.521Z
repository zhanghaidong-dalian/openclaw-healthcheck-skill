{"type":"message","id":"4fd738ac","parentId":"920b5b1c","timestamp":"2026-04-27T23:59:45.937Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建主入口脚本，将所有功能整合在一起。","thinkingSignature":"reasoning_content"},{"type":"text","text":"### Step 7: 创建主入口脚本"},{"type":"toolCall","id":"019dd1621f1457bc298150f99e071b84","name":"write","arguments":{"content":"#!/bin/bash\n# healthcheck-skill v5.0.0 - 主入口\n# 智能化、分层级、可配置的系统安全加固工具\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nVERSION=\"5.0.0\"\nBUILD_DATE=\"2026-04-28\"\n\n# 颜色输出\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nCYAN='\\033[0;36m'\nMAGENTA='\\033[0;35m'\nBOLD='\\033[1m'\nNC='\\033[0m'\n\n# 日志函数\nlog_info() {\n    echo -e \"${BLUE}[INFO]${NC} $*\"\n}\n\nlog_success() {\n    echo -e \"${GREEN}[SUCCESS]${NC} $*\"\n}\n\nlog_warning() {\n    echo -e \"${YELLOW}[WARNING]${NC} $*\"\n}\n\nlog_error() {\n    echo -e \"${RED}[ERROR]${NC} $*\"\n}\n\n# 显示横幅\nshow_banner() {\n    cat << \"EOF\"\n${CYAN}██╗  ██╗ █████╗  ██████╗██╗  ██╗███████╗██╗     ██╗███╗   ██╗ ██████╗ ${NC}\n${CYAN}██║  ██║██╔══██╗██╔════╝██║ ██╔╝██╔════╝██║     ██║████╗  ██║██╔════╝ ${NC}\n${CYAN}███████║███████║██║     █████╔╝ █████╗  ██║     ██║██╔██╗ ██║██║  ███╗${NC}\n${CYAN}██╔══██║██╔══██║██║     ██╔═██╗ ██╔══╝  ██║     ██║██║╚██╗██║██║   ██║${NC}\n${CYAN}██║  ██║██║  ██║╚██████╗██║  ██╗███████╗███████╗██║██║ ╚████║╚██████╔╝${NC}\n${CYAN}╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝╚══════╝╚══════╝╚═╝╚═╝  ╚═══╝ ╚═════╝ ${NC}\n${BOLD}                   v${VERSION} - 智能化系统安全加固工具${NC}\n${BOLD}                   构建日期: ${BUILD_DATE}${NC}\nEOF\n    echo \"\"\n}\n\n# 显示帮助\nshow_help() {\n    cat << EOF\n${BOLD}用法:${NC}\n  $0 [选项] [参数]\n\n${BOLD}扫描选项:${NC}\n  --quick               轻量级扫描（< 30秒，扫描高风险项）\n  --deep                深度扫描（3-5分钟，扫描所有检查项）\n  --intelligent         智能扫描（5-10分钟，LLM 辅助分析）\n  --auto                自动选择扫描模式\n\n${BOLD}规则管理:${NC}\n  --list-rules          列出所有规则\n  --validate-rule <规则> 验证规则文件\n  --load-rules          加载所有规则\n\n${BOLD}白名单管理:${NC}\n  --init-whitelist      初始化白名单\n  --add-whitelist-domain <域名>  添加域名到白名单\n  --add-whitelist-path <路径>    添加路径到白名单\n  --list-whitelist      列出所有白名单\n  --check-whitelist     验证白名单\n\n${BOLD}报告输出:${NC}\n  --output json [文件]  JSON 格式输出\n  --output markdown [文件] Markdown 格式输出\n  --output both [前缀] 双格式输出\n\n${BOLD}其他选项:${NC}\n  --version             显示版本信息\n  --help                显示此帮助信息\n\n${BOLD}示例:${NC}\n  # 快速安全检查\n  $0 --quick\n\n  # 全面安全审计\n  $0 --deep\n\n  # 智能分析\n  $0 --intelligent\n\n  # 自动推荐模式\n  $0 --auto\n\n  # JSON 格式输出\n  $0 --quick --output json /tmp/report.json\n\n  # Markdown 格式输出\n  $0 --deep --output markdown /tmp/report.md\n\n  # 双格式输出\n  $0 --intelligent --output both /tmp/report\n\n${BOLD}扫描策略:${NC}\n  ${CYAN}轻量级扫描${NC}  - 快速检测 6 个高风险项，适合日常巡检\n  ${CYAN}深度扫描${NC}    - 全面扫描 18 个检查项，适合上线前检查\n  ${CYAN}智能扫描${NC}    - 深度扫描 + 意图一致性检查，适合高安全要求场景\n\n${BOLD}新功能 (v5.0.0):${NC}\n  ✅ 分层扫描策略（轻量/深度/智能）\n  ✅ 规则体系化（24 个规则文件）\n  ✅ 意图一致性检查\n  ✅ 结构化输出（JSON/Markdown）\n  ✅ 白名单机制（域名/路径/服务）\n\nEOF\n}\n\n# 显示版本\nshow_version() {\n    cat << EOF\nhealthcheck-skill v${VERSION}\n构建日期: ${BUILD_DATE}\n作者: luck 🍀\n许可证: MIT\n\n基于 Skill 安全扫描评测的借鉴点\n完整升级规划: PLAN-v5.0.0.md\nEOF\n}\n\n# 执行扫描\nrun_scan() {\n    local scan_type=\"$1\"\n\n    # 初始化白名单\n    if [[ ! -f \"${SCRIPT_DIR}/../config/whitelist.yaml\" ]]; then\n        log_info \"初始化白名单...\"\n        \"${SCRIPT_DIR}/whitelist-manager.sh\" --init 2>/dev/null || true\n    fi\n\n    # 执行扫描\n    local report_file\n    case \"$scan_type\" in\n        quick)\n            report_file=$(\"${SCRIPT_DIR}/layered-scanner.sh\" --quick)\n            ;;\n        deep)\n            report_file=$(\"${SCRIPT_DIR}/layered-scanner.sh\" --deep)\n            ;;\n        intelligent)\n            report_file=$(\"${SCRIPT_DIR}/layered-scanner.sh\" --intelligent)\n            ;;\n        auto)\n            report_file=$(\"${SCRIPT_DIR}/layered-scanner.sh\" --auto)\n            ;;\n        *)\n            log_error \"未知扫描类型: $scan_type\"\n            return 1\n            ;;\n    esac\n\n    if [[ -n \"$report_file\" ]] && [[ -f \"$report_file\" ]]; then\n        # 默认输出到控制台\n        \"${SCRIPT_DIR}/report-generator.sh\" --console \"$report_file\"\n\n        # 保存报告文件路径\n        echo \"$report_file\"\n    else\n        log_error \"扫描失败，未生成报告\"\n        return 1\n    fi\n}\n\n# 主函数\nmain() {\n    local action=\"${1:-}\"\n    shift 2>/dev/null || true\n\n    # 显示横幅（非 help/version）\n    if [[ \"$action\" != \"--help\" ]] && [[ \"$action\" != \"--version\" ]]; then\n        show_banner\n    fi\n\n    case \"$action\" in\n        --quick|--deep|--intelligent|--auto)\n            local report_file\n            report_file=$(run_scan \"${action#--}\")\n\n            # 检查是否需要特定输出格式\n            if [[ \"${1:-}\" == \"--output\" ]]; then\n                local output_format=\"${2:-console}\"\n                local output_file=\"${3:-}\"\n\n                case \"$output_format\" in\n                    json)\n                        \"${SCRIPT_DIR}/report-generator.sh\" --json \"$report_file\" \"$output_file\"\n                        ;;\n                    markdown)\n                        \"${SCRIPT_DIR}/report-generator.sh\" --markdown \"$report_file\" \"$output_file\"\n                        ;;\n                    both)\n                        \"${SCRIPT_DIR}/report-generator.sh\" --both \"$report_file\" \"$output_file\"\n                        ;;\n                    *)\n                        log_warning \"未知输出格式: $output_format，使用默认控制台输出\"\n                        ;;\n                esac\n            fi\n            ;;\n        --list-rules)\n            \"${SCRIPT_DIR}/rule-engine.sh\" --list\n            ;;\n        --validate-rule)\n            \"${SCRIPT_DIR}/rule-engine.sh\" --validate \"$@\"\n            ;;\n        --load-rules)\n            \"${SCRIPT_DIR}/rule-engine.sh\" --load-all\n            ;;\n        --init-whitelist)\n            \"${SCRIPT_DIR}/whitelist-manager.sh\" --init\n            ;;\n        --add-whitelist-domain)\n            shift\n            \"${SCRIPT_DIR}/whitelist-manager.sh\" --add-domain \"$@\"\n            ;;\n        --add-whitelist-path)\n            shift\n            \"${SCRIPT_DIR}/whitelist-manager.sh\" --add-path \"$@\"\n            ;;\n        --list-whitelist)\n            \"${SCRIPT_DIR}/whitelist-manager.sh\" --list\n            ;;\n        --check-whitelist)\n            \"${SCRIPT_DIR}/whitelist-manager.sh\" --check\n            ;;\n        --version|--v)\n            show_version\n            ;;\n        --help|--h|'')\n            show_banner\n            show_help\n            ;;\n        *)\n            log_error \"未知选项: $action\"\n            show_help\n            exit 1\n            ;;\n    esac\n}\n\n# 执行主函数\nmain \"$@\"\n","path":"/workspace/projects/workspace/healthcheck-skill/bin/healthcheck"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":2551,"output":2129,"cacheRead":115136,"cacheWrite":0,"totalTokens":119816,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777334359970,"responseId":"2026042807592005b6bff9856f434f"}}
