me":"@openclaw/zai-provider","version":"2026.4.20","description":"OpenClaw Z.AI provider plugin","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zai/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zai"},{"id":"zalo","name":"@openclaw/zalo","version":"2026.4.20","description":"OpenClaw Zalo channel plugin","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zalo/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zalo"},{"id":"zalouser","name":"@openclaw/zalouser","version":"2026.4.20","description":"OpenClaw Zalo Personal Account plugin via native zca-js integration","origin":"bundled","enabled":false,"explicitlyEnabled":false,"activated":false,"activationSource":"disabled","activationReason":"not in allowlist","status":"disabled","error":"not in allowlist","format":"openclaw","source":"/usr/lib/node_modules/openclaw/dist/extensions/zalouser/index.js","rootDir":"/usr/lib/node_modules/openclaw/dist/extensions/zalouser"}]},"skills":{"snapshotVersion":0,"entries":[{"id":"agent-browser","name":"agent-browser","description":"Browser automation CLI for AI agents. Use when the user needs to interact with websites, including navigating pages, filling forms, clicking buttons, taking screenshots, extracting data, testing web apps, or automating any browser task. Triggers include requests to \"open a website\", \"fill out a form\", \"click a button\", \"take a screenshot\", \"scrape data from a page\", \"test this web app\", \"login to a site\", \"automate browser actions\", or any task requiring programmatic web interaction.","filePath":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser","source":"openclaw-workspace","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser","origin":"top-level","path":"$OPENCLAW_STATE_DIR/workspace/skills/agent-browser/SKILL.md","scope":"project","source":"openclaw-workspace"},"disableModelInvocation":false,"available":true},{"id":"coze-asr","name":"coze-asr","description":"Convert speech audio to text using Coze ASR. Use when you need to transcribe spoken content from a remote audio URL or a local audio file into plain text.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-asr/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"coze-image-gen","name":"coze-image-gen","description":"Generate one or more images from text prompts using Coze image generation. Use when you need to create images from a natural-language prompt, produce multiple image variants, or generate sequential frames from the same prompt.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-image-gen/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"coze-tts","name":"coze-tts","description":"Convert text to speech using Coze TTS. Use when you need to synthesize spoken audio from one text input or multiple text segments, optionally with a specific speaker, format, sample rate, or speech settings.","filePath":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/coze-openclaw-plugin/skills/coze-tts/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-bitable","name":"feishu-bitable","description":"飞书多维表格（Bitable）的创建、查询、编辑和管理工具。包含 27 种字段类型支持、高级筛选、批量操作和视图管理。\n\n**当以下情况时使用此 Skill**：\n(1) 需要创建或管理飞书多维表格 App\n(2) 需要在多维表格中新增、查询、修改、删除记录（行数据）\n(3) 需要管理字段（列）、视图、数据表\n(4) 用户提到\"多维表格\"、\"bitable\"、\"数据表\"、\"记录\"、\"字段\"\n(5) 需要批量导入数据或批量更新多维表格","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-bitable/SKILL.md","scope":"project","source":"openclaw-extra"},"disableModelInvocation":false,"available":true},{"id":"feishu-calendar","name":"feishu-calendar","description":"飞书日历与日程管理工具集。包含日历管理、日程管理、参会人管理、忙闲查询。","filePath":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar/SKILL.md","baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar","source":"openclaw-extra","sourceInfo":{"baseDir":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar","origin":"top-level","path":"$OPENCLAW_STATE_DIR/extensions/openclaw-lark/skills/feishu-calendar/SKILL.md","scope":"pro