{"type":"message","id":"3fbfea60","parentId":"d23da26e","timestamp":"2026-05-14T12:50:14.657Z","message":{"role":"toolResult","toolCallId":"call_function_fl5u2pdfnxyn_1","toolName":"read","content":[{"type":"text","text":"    front_freq = analyze_front_balls(records)\n    # 找出所有号码\n    all_balls = set(range(1, 36))\n    appeared = set(front_freq.keys())\n    never_appeared = all_balls - appeared\n    \n    # 选择出现次数最少的号码\n    if len(front_freq) >= count:\n        cold_balls = [ball for ball, freq in front_freq.most_common()[-count:]]\n    else:\n        cold_balls = []\n    \n    # 如果不够5个，补充从未出现的号码\n    result = cold_balls + list(never_appeared)\n    return result[:count]\n\ndef generate_missing_prediction(records, count=5):\n    \"\"\"基于遗漏值生成预测（前区）\"\"\"\n    missing = calculate_missing_days(records, 'front')\n    # 选择遗漏值最大的号码\n    sorted_missing = sorted(missing.items(), key=lambda x: x[1], reverse=True)\n    return [ball for ball, days in sorted_missing[:count]]\n\ndef generate_random_prediction(count=5, ball_range=(1, 35)):\n    \"\"\"生成随机号码\"\"\"\n    return sorted(random.sample(range(ball_range[0], ball_range[1] + 1), count))\n\ndef generate_balanced_prediction(records):\n    \"\"\"生成均衡型预测（结合热号、冷号、随机）\"\"\"\n    # 2个热号\n    hot = generate_hot_number_prediction(records, 2)\n    # 1个冷号\n    cold = generate_cold_number_prediction(records, 1)\n    # 2个遗漏值大的号\n    missing = generate_missing_prediction(records, 2)\n    \n    # 合并并去重\n    combined = hot + cold + missing\n    seen = set()\n    result = []\n    for ball in combined:\n        if ball not in seen and len(result) < 5:\n            seen.add(ball)\n            result.append(ball)\n    \n    # 如果不够5个，随机补足\n    while len(result) < 5:\n        ball = random.randint(1, 35)\n        if ball not in seen:\n            seen.add(ball)\n            result.append(ball)\n    \n    return sorted(result)\n\ndef generate_ml_style_prediction(records):\n    \"\"\"基于加权评分的预测（模拟简单ML模型）\"\"\"\n    front_freq = analyze_front_balls(records)\n    missing = calculate_missing_days(records, 'front')\n    \n    # 计算每个号码的加权分数\n    max_freq = max(front_freq.values()) if front_freq else 1\n    max_missing = max(missing.values()) if missing else 1\n    \n    scores = {}\n    for ball in range(1, 36):\n        freq_score = front_freq.get(ball, 0) / max_freq  # 频率分数\n        missing_score = missing.get(ball, 0) / max_missing  # 遗漏分数\n        # 加权：频率占40%，遗漏占60%\n        scores[ball] = freq_score * 0.4 + missing_score * 0.6\n    \n    # 选择分数最高的5个号码\n    sorted_balls = sorted(scores.items(), key=lambda x: x[1], reverse=True)\n    return [ball for ball, score in sorted_balls[:5]]\n\ndef generate_back_balls_prediction(records, count=2):\n    \"\"\"生成后区号码预测\"\"\"\n    back_freq = analyze_back_balls(records)\n    missing = calculate_missing_days(records, 'back')\n    \n    max_freq = max(back_freq.values()) if back_freq else 1\n    max_missing = max(missing.values()) if missing else 1\n    \n    scores = {}\n    for ball in range(1, 13):\n        freq_score = back_freq.get(ball, 0) / max_freq\n        missing_score = missing.get(ball, 0) / max_missing\n        scores[ball] = freq_score * 0.4 + missing_score * 0.6\n    \n    sorted_balls = sorted(scores.items(), key=lambda x: x[1], reverse=True)\n    return [ball for ball, score in sorted_balls[:count]]\n\ndef print_prediction(title, front_balls, back_balls):\n    \"\"\"打印预测结果\"\"\"\n    print(f\"\\n{'='*50}\")\n    print(f\"📊 {title}\")\n    print(f\"{'='*50}\")\n    print(f\"🎱 前区号码: {' '.join(f'{b:02d}' for b in front_balls)}\")\n    print(f\"🔵 后区号码: {' '.join(f'{b:02d}' for b in back_balls)}\")\n    print(f\"{'='*50}\")\n\ndef print_statistics(records):\n    \"\"\"打印统计信息\"\"\"\n    print(f\"\\n{'='*50}\")\n    print(f\"📈 历史数据统计\")\n    print(f\"{'='*50}\")\n    \n    front_freq = analyze_front_balls(records)\n    back_freq = analyze_back_balls(records)\n    \n    print(f\"\\n🎱 前区号码频率 TOP 10:\")\n    for ball, freq in front_freq.most_common(10):\n        bar = '█' * freq\n        print(f\"   {ball:02d}: {bar} ({freq}次)\")\n    \n    print(f\"\\n🔵 后区号码频率:\")\n    for ball, freq in back_freq.most_common():\n        bar = '█' * freq\n        print(f\"   {ball:02d}: {bar} ({freq}次)\")\n    \n    print(f\"\\n📊 遗漏情况 (前区):\")\n    missing = calculate_missing_days(records, 'front')\n    sorted_missing = sorted(missing.items(), key=lambda x: x[1], reverse=True)[:10]\n    for ball, days in sorted_missing:\n        print(f\"   {ball:02d}: {days}期未出现\")\n\ndef main():\n    parser = argparse.ArgumentParser(description='大乐透预测模型')\n    parser.add_argument('--strategy', '-s', type=str, \n                       choices=['hot', 'cold', 'missing', 'balanced', 'ml', 'all'],\n                       default='all', help='预测策略')\n    parser.add_argument('--count', '-c', type=int, default=3, help='生成几组号码')\n    parser.add_argument('--history', type=int, default=None, help='使用最近多少期数据')\n    parser.add_argument('--stats', action='store_true', help='显示统计信息')\n    args = parser.parse_args()\n    \n    records = get_all_records(args.history)\n    \n    if not records:\n        print(\"❌ 数据库中没有数据，请先运行 fetch_history.py 抓取数据\")\n        return\n    \n    print(f\"\\n🎲 大乐透预测模型\")\n    print(f\"📈 数据来源: 最近 {len(records)} 期历史数据\")\n    \n    # 显示统计信息\n    if args.stats:\n        print_statistics(records)\n    \n    # 生成后区号码池\n    back_balls_pool = list(range(1, 13))\n\n[54 more lines in file. Use offset=250 to continue.]"}],"isError":false,"timestamp":1778763014657}}
{"type":"message","id":"d9f1cff0","parentId":"3fbfea60","timestamp":"2026-05-14T12:51:03.361Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"我需要写一个更详细的预测脚本，结合用户要求的：\n1. 复式5+6（前区5个+后区6个）\n2. 历史规律分析\n3. 近期走势分析\n4. 号码之间的关联性分析\n5. 首尾号关联关系分析\n\n让我直接用Python来生成这个预测。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_function_1p9uvf77exq9_1","name":"exec","arguments":{"command":"cd /workspace/projects/workspace/skills/super-lotto && python3 << 'EOF'\nimport sqlite3\nfrom collections import Counter\nimport random\n\nDB_PATH = 'data/super_lotto.db'\n\nconn = sqlite3.connect(DB_PATH)\ncursor = conn.cursor()\n\n# 获取所有记录\ncursor.execute('SELECT * FROM lottery_records ORDER BY issue_number DESC')\nall_records = cursor.fetchall()\n\n# 获取最近30期\ncursor.execute('SELECT * FROM lottery_records ORDER BY issue_number DESC LIMIT 30')\nrecent_30 = cursor.fetchall()\n\nprint(f\"📊 数据来源: {len(all_records)} 期历史数据\")\nprint(f\"📅 最近30期分析\")\n\n# 1. 分析前区号码频率\nfront_freq = Counter()\nfor r in all_records:\n    front_freq.update(r[3:8])\n\n# 2. 分析后区号码频率\nback_freq = Counter()\nfor r in all_records:\n    back_freq.update([r[8], r[9]])\n\n# 3. 分析最近30期前区频率（近期走势）\nrecent_front_freq = Counter()\nfor r in recent_30:\n    recent_front_freq.update(r[3:8])\n\n# 4. 分析最近30期后区频率\nrecent_back_freq = Counter()\nfor r in recent_30:\n    recent_back_freq.update([r[8], r[9]])\n\n# 5. 计算遗漏值\nlatest_issue = int(all_records[0][1])\nfront_missing = {}\nback_missing = {}\nfor ball in range(1, 36):\n    cursor.execute('''\n        SELECT issue_number FROM lottery_records \n        WHERE front_ball_1=? OR front_ball_2=? OR front_ball_3=? OR front_ball_4=? OR front_ball_5=?\n        ORDER BY issue_number DESC LIMIT 1\n    ''', (ball, ball, ball, ball, ball))\n    result = cursor.fetchone()\n    front_missing[ball] = latest_issue - int(result[0]) if result else 999\n\nfor ball in range(1, 13):\n    cursor.execute('''\n        SELECT issue_number FROM lottery_records \n        WHERE back_ball_1=? OR back_ball_2=?\n        ORDER BY issue_number DESC LIMIT 1\n    ''', (ball, ball))\n    result = cursor.fetchone()\n    back_missing[ball] = latest_issue - int(result[0]) if result else 999\n\n# 6. 首尾号分析（最近30期）\nprint(\"\\n\" + \"=\"*60)\nprint(\"🔍 首尾号关联分析\")\nprint(\"=\"*60)\n\nfirst_balls = [r[3] for r in recent_30]  # 第一位\nlast_balls = [r[7] for r in recent_30]    # 第五位\nprint(f\"📊 最近30期首号(最小前区): {Counter(first_balls).most_common(5)}\")\nprint(f\"📊 最近30期末号(最大前区): {Counter(last_balls).most_common(5)}\")\n\n# 首号+末号和值分析\nsums = [sum(r[3:8]) for r in recent_30]\nprint(f\"📊 最近30期前区和值范围: {min(sums)}-{max(sums)}, 均值: {sum(sums)/len(sums):.1f}\")\n\n# 7. 号码关联性分析 - 相邻号码组合\nadjacent_pairs = Counter()\nfor r in recent_30:\n    balls = sorted(r[3:8])\n    for i in range(4):\n        for j in range(i+1, 5):\n            pair = tuple(sorted([balls[i], balls[j]]))\n            adjacent_pairs[pair] += 1\n\nprint(f\"\\n📊 高频号码组合(TOP10):\")\nfor pair, count in adjacent_pairs.most_common(10):\n    print(f\"   {pair[0]:02d}-{pair[1]:02d}: {count}次\")\n\n# 8. 前后区关联\nprint(\"\\n📊 前后区关联(最近30期):\")\nfront_sum_means = [sum(r[3:8]) for r in recent_30]\nback_sum_means = [r[8]+r[9] for r in recent_30]\nprint(f\"   前区和值: 均值={sum(front_sum_means)/30:.1f}, 范围={min(front_sum_means)}-{max(front_sum_means)}\")\nprint(f\"   后区和值: 均值={sum(back_sum_means)/30:.1f}, 范围={min(back_sum_means)}-{max(back_sum_means)}\")\n\n# ============ 生成预测 ============\nprint(\"\\n\" + \"=\"*60)\nprint(\"🎯 复式预测结果 (5+6)\")\nprint(\"=\"*60)\n\n# 前区预测：综合评分\nfront_scores = {}\nfor ball in range(1, 36):\n    freq_score = front_freq.get(ball, 0) / max(front_freq.values())  # 历史频率\n    recent_score = recent_front_freq.get(ball, 0) / max(recent_front_freq.values())  # 近期频率\n    miss_score = front_missing.get(ball, 0) / max(front_missing.values())  # 遗漏\n    # 综合评分: 历史30% + 近期40% + 遗漏30%\n    front_scores[ball] = freq_score * 0.3 + recent_score * 0.4 + miss_score * 0.3\n\n# 按评分排序选择前区\nsorted_front = sorted(front_scores.items(), key=lambda x: x[1], reverse=True)\n\n# 选择前区：优先近期热号+遗漏号\nfront_candidates = []\n# 近期TOP3热号\nfor ball, _ in sorted(front_scores.items(), key=lambda x: recent_front_freq.get(x[0], 0), reverse=True)[:4]:\n    front_candidates.append(ball)\n# 近期遗漏TOP3\nfor ball, _ in sorted(front_scores.items(), key=lambda x: front_missing.get(x[0], 0), reverse=True)[:4]:\n    front_candidates.append(ball)\n# 综合评分TOP3\nfor ball, _ in sorted_front[:5]:\n    front_candidates.append(ball)\n\n# 最终选择5个，确保多样性\nfinal_front = []\nseen_diffs = set()\nfor ball in front_candidates:\n    if len(final_front) >= 5:\n        break\n    if ball not in final_front:\n        # 确保首尾跨度在合理范围\n        if not final_front:\n            final_front.append(ball)\n        else:\n            # 计算与已有号码的差值，避免重复模式\n            diffs = [abs(ball - x) for x in final_front]\n            if min(diffs) >= 2:  # 避免连续号码\n                final_front.append(ball)\n\n# 如果不够5个，补充\nwhile len(final_front) < 5:\n    for ball in range(1, 36):\n        if ball not in final_front:\n            final_front.append(ball)\n            break\n\nfinal_front = sorted(final_front[:5])\n\n# 后区预测：选择6个\nback_scores = {}\nfor ball in range(1, 13):\n    freq_score = back_freq.get(ball, 0) / max(back_freq.values())\n    recent_score = recent_back_freq.get(ball, 0) / max(recent_back_freq.values())\n    miss_score = back_missing.get(ball, 0) / max(back_missing.values())\n    back_scores[ball] = freq_score * 0.3 + recent_score * 0.4 + miss_score * 0.3\n\nsorted_back = sorted(back_scores.items(), key=lambda x: x[1], reverse=True)\n\n# 选择后区：近期热号 + 遗漏号\nback_candidates = []\nfor ball, _ in sorted(back_scores.items(), key=lambda x: recent_back_freq.get(x[0], 0), reverse=True)[:4]:\n    back_candidates.append(ball)\nfor ball, _ in sorted(back_scores.items(), key=lambda x: back_missing.get(x[0], 0), reverse=True)[:4]:\n    back_candidates.append(ball)\n\nfinal_back = sorted(list(set(back_candidates))[:6])\n\nprint(f\"\\n🎱 前区(5个): {' '.join(f'{b:02d}' for b in final_front)}\")\nprint(f\"🔵 后区(6个): {' '.join(f'{b:02d}' for b in final_back)}\")\nprint(f\"\\n📋 完整复式: {' '.join(f'{b:02d}' for b in final_front)} + {' '.join(f'{b:02d}' for b in final_back)}\")\nprint(f\"💰 注数: {6 * 6} 注 (复式5+6)\")\n\n# 号码特征分析\nprint(f\"\\n📊 预测号码特征:\")\nprint(f\"   首号: {min(final_front):02d}, 末号: {max(final_front):02d}\")\nprint(f\"   前区和值: {sum(final_front)}\")\nprint(f\"   奇偶比: {sum(1 for x in final_front if x%2==1)}:{sum(1 for x in final_front if x%2==0)}\")\nprint(f\"   大小比: {sum(1 for x in final_front if x>17)}:{sum(1 for x in final_front if x<=17)}\")\n\nconn.close()\nEOF"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":2547,"output":2135,"cacheRead":85563,"cacheWrite":0,"totalTokens":90245,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1778763014660,"responseId":"0654f80707894f77c5237e9511eeba52","responseModel":"MiniMax-M2.7"}}
