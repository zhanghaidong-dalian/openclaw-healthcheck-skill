{"type":"message","id":"44f526a7","parentId":"32cbc54e","timestamp":"2026-05-14T09:47:16.991Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"\n官方API被拦截了。让我创建一个新的脚本，使用分批抓取的方式，每次抓取一页或小范围的数据，然后循环获取全部历史。\n\n或者我可以让脚本自动检测500彩票网的参数限制，然后分批抓取。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"tool-2e618db75f4048ba83b254bc7ad5abdd","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n双色球历史数据爬虫脚本（分批抓取版）\n通过分批请求获取全部历史数据\n\"\"\"\n\nimport sqlite3\nimport requests\nfrom datetime import datetime\nfrom pathlib import Path\nfrom bs4 import BeautifulSoup\nimport time\n\n# 数据库路径\nDB_PATH = Path(__file__).parent.parent / \"data\" / \"double_color_ball.db\"\n\n# 请求头\nHEADERS = {\n    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',\n    'Accept-Language': 'zh-CN,zh;q=0.9,en;q=0.8',\n}\n\n\ndef parse_html(html_content):\n    \"\"\"解析HTML内容，提取开奖数据\"\"\"\n    records = []\n    soup = BeautifulSoup(html_content, 'html.parser')\n\n    rows = soup.find_all('tr', {'class': 't_tr1'})\n\n    for row in rows:\n        try:\n            tds = row.find_all('td')\n            if len(tds) < 15:\n                continue\n\n            issue_number = tds[1].get_text(strip=True)\n\n            red_balls = []\n            for i in range(2, 8):\n                ball_str = tds[i].get_text(strip=True)\n                ball_str = ball_str.split()[0] if ball_str else ''\n                if ball_str.isdigit():\n                    red_balls.append(int(ball_str))\n\n            blue_str = tds[8].get_text(strip=True)\n            blue_str = blue_str.split()[0] if blue_str else ''\n            if not blue_str.isdigit():\n                continue\n            blue_ball = int(blue_str)\n\n            draw_date_str = tds[-1].get_text(strip=True)\n            if not draw_date_str:\n                continue\n\n            try:\n                draw_date = datetime.strptime(draw_date_str, '%Y-%m-%d').date()\n            except:\n                continue\n\n            if len(red_balls) == 6 and blue_ball:\n                records.append({\n                    'issue_number': issue_number,\n                    'draw_date': draw_date,\n                    'red_balls': red_balls,\n                    'blue_ball': blue_ball\n                })\n\n        except Exception as e:\n            continue\n\n    return records\n\n\ndef fetch_batch(start_issue, end_issue):\n    \"\"\"抓取一批数据\"\"\"\n    url = f\"https://datachart.500.com/ssq/history/newinc/history.php?start={start_issue}&end={end_issue}\"\n\n    try:\n        response = requests.get(url, headers=HEADERS, timeout=30)\n        response.raise_for_status()\n        records = parse_html(response.content)\n        return records\n    except Exception as e:\n        print(f\"   ❌ 批次 {start_issue}-{end_issue} 失败: {e}\")\n        return []\n\n\ndef fetch_all_history():\n    \"\"\"分批抓取全部历史数据\"\"\"\n    print(\"=\" * 60)\n    print(\"🎲 双色球历史数据抓取（分批版）\")\n    print(\"=\" * 60)\n\n    all_records = []\n\n    # 按年份分批抓取\n    batches = [\n        ('03001', '0352'),  # 2003年\n        ('04001', '0453'),  # 2004年\n        ('05001', '0554'),  # 2005年\n        ('06001', '0653'),  # 2006年\n        ('07001', '0753'),  # 2007年\n        ('08001', '0854'),  # 2008年\n        ('09001', '0953'),  # 2009年\n        ('10001', '1054'),  # 2010年\n        ('11001', '1154'),  # 2011年\n        ('12001', '1253'),  # 2012年\n        ('13001', '1354'),  # 2013年\n        ('14001', '1453'),  # 2014年\n        ('15001', '1554'),  # 2015年\n        ('16001', '1654'),  # 2016年\n        ('17001', '1753'),  # 2017年\n        ('18001', '1853'),  # 2018年\n        ('19001', '1954'),  # 2019年\n        ('20001', '2053'),  # 2020年\n        ('21001', '2154'),  # 2021年\n        ('22001', '2254'),  # 2022年\n        ('23001', '2353'),  # 2023年\n        ('24001', '2454'),  # 2024年\n        ('25001', '2553'),  # 2025年\n        ('26001', '26053'), # 2026年\n    ]\n\n    for start, end in batches:\n        print(f\"\\n📄 正在抓取 {start} ~ {end}...\")\n        records = fetch_batch(start, end)\n\n        if records:\n            all_records.extend(records)\n            print(f\"   ✅ 成功抓取 {len(records)} 条\")\n        else:\n            print(f\"   ⚠️ 该批次无数据\")\n\n        # 避免请求过快\n        time.sleep(0.5)\n\n    print(f\"\\n📊 总计抓取: {len(all_records)} 条记录\")\n\n    # 去重\n    unique_records = {}\n    for record in all_records:\n        unique_records[record['issue_number']] = record\n    all_records = list(unique_records.values())\n\n    print(f\"📊 去重后: {len(all_records)} 条记录\")\n\n    # 保存到数据库\n    if all_records:\n        saved = save_to_database(all_records)\n        print(f\"\\n✅ 总计保存 {saved} 条记录\")\n        return saved\n\n    return 0\n\n\ndef save_to_database(records):\n    \"\"\"保存数据到数据库\"\"\"\n    if not records:\n        print(\"⚠️ 没有数据需要保存\")\n        return 0\n\n    if not DB_PATH.exists():\n        print(\"❌ 数据库文件不存在，请先运行 init_db.py\")\n        return 0\n\n    conn = sqlite3.connect(DB_PATH)\n    cursor = conn.cursor()\n\n    inserted = 0\n    updated = 0\n\n    for record in records:\n        try:\n            cursor.execute(\n                'SELECT id FROM lottery_records WHERE issue_number = ?',\n                (record['issue_number'],)\n            )\n\n            if cursor.fetchone():\n                cursor.execute('''\n                    UPDATE lottery_records SET\n                        draw_date = ?,\n                        red_ball_1 = ?,\n                        red_ball_2 = ?,\n                        red_ball_3 = ?,\n                        red_ball_4 = ?,\n                        red_ball_5 = ?,\n                        red_ball_6 = ?,\n                        blue_ball = ?,\n                        updated_at = CURRENT_TIMESTAMP\n                    WHERE issue_number = ?\n                ''', (\n                    record['draw_date'],\n                    record['red_balls'][0],\n                    record['red_balls'][1],\n                    record['red_balls'][2],\n                    record['red_balls'][3],\n                    record['red_balls'][4],\n                    record['red_balls'][5],\n                    record['blue_ball'],\n                    record['issue_number']\n                ))\n                updated += 1\n            else:\n                cursor.execute('''\n                    INSERT INTO lottery_records (\n                        issue_number, draw_date,\n                        red_ball_1, red_ball_2, red_ball_3,\n                        red_ball_4, red_ball_5, red_ball_6,\n                        blue_ball\n                    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n                ''', (\n                    record['issue_number'],\n                    record['draw_date'],\n                    record['red_balls'][0],\n                    record['red_balls'][1],\n                    record['red_balls'][2],\n                    record['red_balls'][3],\n                    record['red_balls'][4],\n                    record['red_balls'][5],\n                    record['blue_ball']\n                ))\n                inserted += 1\n\n        except Exception as e:\n            continue\n\n    conn.commit()\n    conn.close()\n\n    print(f\"✅ 数据保存完成: 新增 {inserted} 条, 更新 {updated} 条\")\n    return inserted + updated\n\n\nif __name__ == \"__main__\":\n    import sys\n\n    if not DB_PATH.exists():\n        print(\"⚠️ 数据库未初始化，正在初始化...\")\n        import init_db\n        init_db.init_database()\n\n    fetch_all_history()","path":"/workspace/projects/workspace/skills/double-color-ball/scripts/fetch_history.py"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":461,"output":1967,"cacheRead":73984,"cacheWrite":0,"totalTokens":76412,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stop