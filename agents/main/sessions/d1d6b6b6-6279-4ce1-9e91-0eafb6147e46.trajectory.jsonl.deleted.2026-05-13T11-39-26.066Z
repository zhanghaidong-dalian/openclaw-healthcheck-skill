续每天的反馈审查就会简洁很多。"}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":521,"output":804,"cacheRead":63611,"cacheWrite":0,"totalTokens":64936,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1777023239944,"responseId":"063a6c081ae83ac72e1dcf374d8077f3"}],"imagesCount":0}}
