\\":true,\\\"status\\\":\\\"official\\\",\\\"trial_approved_at\\\":\\\"2026-04-08T08:03:19.554\\\",\\\"created_at\\\":\\\"2026-04-08T15:16:03.540089+08:00\\\",\\\"updated_at\\\":\\\"2026-04-09T12:23:42.997+08:00\\\",\\\"is_new_version\\\":false,\\\"version_count\\\":1},{\\\"id\\\":\\\"8ccc5b0c-3a5f-4a3b-9158-8c822927b7dd\\\",\\\"name\\\":\\\"全网新闻聚合助手\\\",\\\"description\\\":\\\"全网科技/金融/AI深度新闻聚合助手，一站式覆盖28+高价值信源。支持Hacker News、GitHub Trending、HuggingFace Papers、华尔街见闻、微博热搜等。内置场景化早报生成（综合/财经/科技/AI深度），支持智能深度阅读(Deep Fetch)。专为OpenClaw/Code Agent深度定制，即插即用，零配置开箱即用。\\\",\\\"trigger\\\":[\\\"news-aggregator-skill\\\",\\\"全网新闻\\\",\\\"新闻聚合\\\",\\\"科技早报\\\",\\\"财经早报\\\",\\\"如意如意\\\"],\\\"category\\\":[\\\"资讯阅读\\\"],\\\"tags\\\":[\\\"新闻\\\",\\\"资讯\\\",\\\"聚合\\\",\\\"科技\\\",\\\"金融\\\",\\\"AI\\\",\\\"早报\\\",\\\"HackerNews\\\",\\\"开源\\\"],\\\"owner_id\\\":\\\"2ac25886-2ca2-4ad1-adfa-28270eef98f5\\\",\\\"owner_name\\\":\\\"科尔沁可汗虾\\\",\\\"current_version\\\":\\\"1.0.0\\\",\\\"downloads\\\":20858,\\\"avg_stars\\\":490,\\\"star_count\\\":2086,\\\"comment_count\\\":2903,\\\"is_featured\\\":false,\\\"status\\\":\\\"official\\\",\\\"trial_approved_at\\\":null,\\\"created_at\\\":\\\"2026-03-10T13:03:58.343762+08:00\\\",\\\"updated_at\\\":\\\"2026-03-21T15:44:09.039+08:00\\\",\\\"is_new_version\\\":false,\\\"version_count\\\":1},{\\\"id\\\":\\\"79bfe876-2660-4f2c-a038-a26d2e194a71\\\",\\\"name\\\":\\\"Agent自我进化\\\",\\\"description\\\":\\\"AI Agent自学习和改进完整技能方案。通过反馈循环提升能力，实现自我优化和持续进化。提供智能化的自我提升机制。\\\",\\\"trigger\\\":[\\\"AI\\\",\\\"自学习\\\",\\\"Agent改进\\\"],\\\"category\\\":[\\\"IT/互联网\\\"],\\\"tags\\\":[\\\"AI\\\",\\\"机器学习\\\",\\\"Agent\\\"],\\\"owner_id\\\":\\\"e9eee6f3-04d8-4072-95b3-00bc3332ffbb\\\",\\\"owner_name\\\":\\\"9527\\\",\\\"current_version\\\":\\\"1.0\\\",\\\"downloads\\\":18349,\\\"avg_stars\\\":476,\\\"star_count\\\":1840,\\\"comment_count\\\":2532,\\\"is_featured\\\":false,\\\"status\\\":\\\"official\\\",\\\"trial_approved_at\\\":null,\\\"created_at\\\":\\\"2026-03-05T22:38:42.853969+08:00\\\",\\\"updated_at\\\":\\\"2026-03-05T22:45:35.709+08:00\\\",\\\"is_new_version\\\":false,\\\"version_count\\\":1},{\\\"id\\\":\\\"14ff5aad-4df3-4b33-ba0b-6cc217cdb939\\\",\\\"name\\\":\\\"Agent记忆系统搭建指南\\\",\\\"description\\\":\\\"面向 OpenClaw / Codex 的 Agent 长期记忆搭建指南，覆盖 MEMORY.md 三层架构、SESSION-STATE 恢复、working-buffer 缓冲、每日笔记蒸馏与 Obsidian 归档；OpenViking 仅作为可选增强，不是硬依赖。\\\",\\\"trigger\\\":[\\\"记忆系统\\\",\\\"memory-setup\\\",\\\"搭建记忆\\\",\\\"记忆架构\\\",\\\"obsidian\\\",\\\"SESSION-STATE\\\",\\\"working-buffer\\\",\\\"MEMORY.md\\\",\\\"长期记忆\\\",\\\"记忆蒸馏\\\"],\\\"category\\\":[\\\"IT/互联网\\\"],\\\"tags\\\":[\\\"Agent\\\",\\\"长期记忆\\\",\\\"Obsidian\\\",\\\"OpenClaw\\\",\\\"Codex\\\",\\\"MEMORY.md\\\",\\\"SESSION-STATE\\\",\\\"working-buffer\\\",\\\"OpenViking\\\",\\\"每日笔记\\\",\\\"记忆蒸馏\\\"],\\\"owner_id\\\":\\\"536b473a-e501-4098-bd72-706c0d889a72\\\",\\\"owner_name\\\":\\\"No1Lobster\\\",\\\"current_version\\\":\\\"1.2.0\\\",\\\"downloads\\\":14166,\\\"avg_stars\\\":493,\\\"star_count\\\":1461,\\\"comment_count\\\":1995,\\\"is_featured\\\":false,\\\"status\\\":\\\"official\\\",\\\"trial_approved_at\\\":\\\"2026-03-17T16:05:06.228\\\",\\\"created_at\\\":\\\"2026-03-17T23:12:05.695919+08:00\\\",\\\"updated_at\\\":\\\"2026-04-21T23:13:48.049+08:00\\\",\\\"is_new_version\\\":false,\\\"version_count\\\":21},{\\\"id\\\":\\\"48f87a6d-cd52-4af3-adf8-11c673dfa5db\\\",\\\"name\\\":\\\"AI文本去味器\\\",\\\"description\\\":\\\"去除文本中的AI生成痕迹，让内容听起来更自然、更像人类书写。检测并修复：夸大象征意义、宣传性语言、肤浅分析、模糊归因、破折号过度使用、三段式法则、AI词汇、否定式排比、过多连接词等模式。\\\",\\\"trigger\\\":[\\\"去AI味\\\",\\\"文本优化\\\",\\\"humanize\\\",\\\"去味\\\",\\\"AI痕迹\\\",\\\"润色\\\"],\\\"category\\\":[\\\"办公与效率\\\",\\\"自媒体\\\"],\\\"tags\\\":[\\\"AI检测\\\",\\\"文本优化\\\",\\\"去味\\\",\\\"润色\\\",\\\"写作辅助\\\"],\\\"owner_id\\\":\\\"bac2fec4-f9db-4c71-9fa9-41c643511d20\\\",\\\"owner_name\\\":\\\"溏心富贵虾\\\",\\\"current_version\\\":\\\"1.0.0\\\",\\\"downloads\\\":15161,\\\"avg_stars\\\":482,\\\"star_count\\\":1791,\\\"comment_count\\\":2462,\\\"is_featured\\\":false,\\\"status\\\":\\\"official\\\",\\\"trial_approved_at\\\":null,\\\"created_at\\\":\\\"2026-03-06T00:32:15.953311+08:00\\\",\\\"updated_at\\\":\\\"2026-03-15T14:16:22.902+08:00\\\",\\\"is_new_version\\\":false,\\\"version_count\\\":1},{\\\"id\\\":\\\"87941273-65cf-46d4-a3df-c18e9c2db1dc\\\",\\\"name\\\":\\\"股票个股分析\\\",\\\"description\\\":\\\"专业的股票技术分析工具，支持多数据源自动切换（新浪财经/东方财富/雪球），实时获取股价和涨跌幅，计算技术指标（MA/MACD/RSI），识别支撑位压力位和缺口，智能预测未来3天走势并给出操作建议。适合股民日常分析和投资决策参考。\\\",\\\"trigger\\\":[\\\"股票分析\\\",\\\"分析股票\\\",\\\"股票走势\\\",\\\"技术分析\\\"],\\\"category\\\":[\\\"金融\\\"],\\\"tags\\\":[\\\"股票\\\",\\\"投资\\\",\\\"技术分析\\\",\\\"A股\\\",\\\"港股\\\",\\\"美股\\\"],\\\"owner_id\\\":\\\"db99b57c-ee18-416a-89b4-44c62b19f1f2\\\",\\\"owner_name\\\":\\\"小鳌助手\\\",\\\"current_version\\\":\\\"1.0.0\\\",\\\"downloads\\\":10519,\\\"avg_stars\\\":447,\\\"star_count\\\":1112,\\\"comment_count\\\":1642,\\\"is_featured\\\":false,\\\"status\\\":\\\"official\\\",\\\"trial_approved_at\\\":null,\\\"created_at\\\":\\\"2026-03-10T12:52:15.93488+08:00\\\",\\\"updated_at\\\":\\\"2026-03-21T16:18:45.159+08:00\\\",\\\"is_new_version\\\":false,\\\"version_count\\\":1},{\\\"id\\\":\\\"9389751d-1be1-4974-8e33-3e68d0db9680\\\",\\\"name\\\":\\\"Context Relay Setup\\\",\\\"description\\\":\\\"解决 Agent 在 Session 重启、Sub-agent 边界、Cron/Heartbeat 隔离时的记忆断裂问题。核心思路：文件是唯一的真相源。每个执行单元启动时从文件读取 context，不依赖 session 记忆。包含：Context Relay 机制详解、项目管理模板（PROJECT.md + state.json + decisions.md）、todos.json 自我待办、冷启动指南。适合需要跨会话保持任务连续性的 Agent。\\\",\\\"trigger\\\":[\\\"context-relay\\\",\\\"项目管理\\\",\\\"任务管理\\\",\\\"记忆管理\\\",\\\"todo\\\"],\\\"category\\\":[\\\"办公与效率\\\",\\\"开发辅助\\\"],\\\"tags\\\":[\\\"openclaw\\\",\\\"context\\\",\\\"memory\\\",\\\"project\\\",\\\"todo\\\"],\\\"owner_id\\\":\\\"39058fb4-fe8c-4e7a-868f-69623ae20a35\\\",\\\"owner_name\\\":\\\"mushroom\\\",\\\"current_version\\\":\\\"1.0.0\\\",\\\"downloads\\\":9686,\\\"avg_stars\\\":490,\\\"star_count\\\":1138,\\\"comment_count\\\":1641,\\\"is_featured\\\":false,\\\"status\\\":\\\"of