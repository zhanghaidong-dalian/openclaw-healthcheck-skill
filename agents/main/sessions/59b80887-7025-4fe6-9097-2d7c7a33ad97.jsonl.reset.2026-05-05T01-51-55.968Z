\\\"id\\\":\\\"9389751d-1be1-4974-8e33-3e68d0db9680\\\",\\\"name\\\":\\\"Context Relay Setup\\\",\\\"description\\\":\\\"解决 Agent 在 Session 重启、Sub-agent 边界、Cron/Heartbeat 隔离时的记忆断裂问题。核心思路：文件是唯一的真相源。每个执行单元启动时从文件读取 context，不依赖 session 记忆。包含：Context Relay 机制详解、项目管理模板（PROJECT.md + state.json + decisions.md）、todos.json 自我待办、冷启动指南。适合需要跨会话保持任务连续性的 Agent。\\\",\\\"trigger\\\":[\\\"context-relay\\\",\\\"项目管理\\\",\\\"任务管理\\\",\\\"记忆管理\\\",\\\"todo\\\"],\\\"category\\\":[\\\"办公与效率\\\",\\\"开发辅助\\\"],\\\"tags\\\":[\\\"openclaw\\\",\\\"context\\\",\\\"memory\\\",\\\"project\\\",\\\"todo\\\"],\\\"owner_id\\\":\\\"39058fb4-fe8c-4e7a-868f-69623ae20a35\\\",\\\"owner_name\\\":\\\"mushroom\\\",\\\"current_version\\\":\\\"1.0.0\\\",\\\"downloads\\\":9686,\\\"avg_stars\\\":490,\\\"star_count\\\":1138,\\\"comment_count\\\":1641,\\\"is_featured\\\":false,\\\"created_at\\\":\\\"2026-03-13T12:54:46.152476+08:00\\\",\\\"updated_at\\\":\\\"2026-03-13T20:44:49.943+08:00\\\"}]}],\\\"$L26\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"27:I[52023,[\\\"/_next/static/chunks/0e76ae43d3fa3f5f.js\\\",\\\"/_next/static/chunks/ccb6539566902bce.js\\\",\\\"/_next/static/chunks/f2aed99dd88f4679.js\\\",\\\"/_next/static/chunks/aa825ea4d785cf2a.js\\\",\\\"/_next/static/chunks/fca158d4b39c9b2b.js\\\",\\\"/_next/static/chunks/374bc96f057405b3.js\\\",\\\"/_next/static/chunks/8d2d1a9a9efdb2b0.js\\\"],\\\"WishWallWidget\\\"]\\n26:[\\\"$\\\",\\\"$L27\\\",null,{\\\"data-inspector-line\\\":\\\"942\\\",\\\"data-inspector-column\\\":\\\"18\\\",\\\"data-inspector-relative-path\\\":\\\"src/app/page.tsx\\\"}]\\n\"])</script></body></html>","cwd":"/workspace/projects/workspace"},"isError":false,"timestamp":1777905314230}}
