# OpenClaw HealthCheck Skill - .gitignore

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
*.log
*.tmp
*.cache

# Node modules (if any)
node_modules/

# Test coverage
coverage/

# Temporary files
*.bak
*.backup

# Personal notes (keep only what's needed for the skill)
memory/*.md
!memory/feedback-and-roadmap.md

# Version control backup files
*.orig
*.rej

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/

# Bash history
.bash_history
