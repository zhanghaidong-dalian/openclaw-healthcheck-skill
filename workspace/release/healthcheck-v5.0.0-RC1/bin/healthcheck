#!/bin/bash
# healthcheck-skill v5.0.0 - 主入口
# 智能化、分层级、可配置的系统安全加固工具

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SCRIPTS_DIR="$SKILL_ROOT/scripts"
RULES_DIR="$SKILL_ROOT/rules"
CONFIG_DIR="$SKILL_ROOT/config"
VERSION="5.0.0"
BUILD_DATE="2026-04-28"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m'

# 日志函数
log_info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $*"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $*"
}

# 显示横幅
show_banner() {
    cat << "EOF"
${CYAN}██╗  ██╗ █████╗  ██████╗██╗  ██╗███████╗██╗     ██╗███╗   ██╗ ██████╗ ${NC}
${CYAN}██║  ██║██╔══██╗██╔════╝██║ ██╔╝██╔════╝██║     ██║████╗  ██║██╔════╝ ${NC}
${CYAN}███████║███████║██║     █████╔╝ █████╗  ██║     ██║██╔██╗ ██║██║  ███╗${NC}
${CYAN}██╔══██║██╔══██║██║     ██╔═██╗ ██╔══╝  ██║     ██║██║╚██╗██║██║   ██║${NC}
${CYAN}██║  ██║██║  ██║╚██████╗██║  ██╗███████╗███████╗██║██║ ╚████║╚██████╔╝${NC}
${CYAN}╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝╚══════╝╚══════╝╚═╝╚═╝  ╚═══╝ ╚═════╝ ${NC}
${BOLD}                   v${VERSION} - 智能化系统安全加固工具${NC}
${BOLD}                   构建日期: ${BUILD_DATE}${NC}
EOF
    echo ""
}

# 显示帮助
show_help() {
    cat << EOF
${BOLD}用法:${NC}
  $0 [选项] [参数]

${BOLD}扫描选项:${NC}
  --quick               轻量级扫描（< 30秒，扫描高风险项）
  --deep                深度扫描（3-5分钟，扫描所有检查项）
  --intelligent         智能扫描（5-10分钟，LLM 辅助分析）
  --auto                自动选择扫描模式

${BOLD}规则管理:${NC}
  --list-rules          列出所有规则
  --validate-rule <规则> 验证规则文件
  --load-rules          加载所有规则

${BOLD}白名单管理:${NC}
  --init-whitelist      初始化白名单
  --add-whitelist-domain <域名>  添加域名到白名单
  --add-whitelist-path <路径>    添加路径到白名单
  --list-whitelist      列出所有白名单
  --check-whitelist     验证白名单

${BOLD}报告输出:${NC}
  --output json [文件]  JSON 格式输出
  --output markdown [文件] Markdown 格式输出
  --output both [前缀] 双格式输出

${BOLD}其他选项:${NC}
  --version             显示版本信息
  --help                显示此帮助信息

${BOLD}示例:${NC}
  # 快速安全检查
  $0 --quick

  # 全面安全审计
  $0 --deep

  # 智能分析
  $0 --intelligent

  # 自动推荐模式
  $0 --auto

  # JSON 格式输出
  $0 --quick --output json /tmp/report.json

  # Markdown 格式输出
  $0 --deep --output markdown /tmp/report.md

  # 双格式输出
  $0 --intelligent --output both /tmp/report

${BOLD}扫描策略:${NC}
  ${CYAN}轻量级扫描${NC}  - 快速检测 6 个高风险项，适合日常巡检
  ${CYAN}深度扫描${NC}    - 全面扫描 18 个检查项，适合上线前检查
  ${CYAN}智能扫描${NC}    - 深度扫描 + 意图一致性检查，适合高安全要求场景

${BOLD}新功能 (v5.0.0):${NC}
  ✅ 分层扫描策略（轻量/深度/智能）
  ✅ 规则体系化（24 个规则文件）
  ✅ 意图一致性检查
  ✅ 结构化输出（JSON/Markdown）
  ✅ 白名单机制（域名/路径/服务）

EOF
}

# 显示版本
show_version() {
    cat << EOF
healthcheck-skill v${VERSION}
构建日期: ${BUILD_DATE}
作者: luck 🍀
许可证: MIT

基于 Skill 安全扫描评测的借鉴点
完整升级规划: PLAN-v5.0.0.md
EOF
}

# 执行扫描
run_scan() {
    local scan_type="$1"

    # 初始化白名单
    if [[ ! -f "${CONFIG_DIR}/whitelist.yaml" ]]; then
        log_info "初始化白名单..."
        "${SCRIPTS_DIR}/whitelist-manager.sh" --init 2>/dev/null || true
    fi

    # 执行扫描
    local report_file
    case "$scan_type" in
        quick)
            report_file=$("${SCRIPTS_DIR}/layered-scanner.sh" --quick)
            ;;
        deep)
            report_file=$("${SCRIPTS_DIR}/layered-scanner.sh" --deep)
            ;;
        intelligent)
            report_file=$("${SCRIPTS_DIR}/layered-scanner.sh" --intelligent)
            ;;
        auto)
            report_file=$("${SCRIPTS_DIR}/layered-scanner.sh" --auto)
            ;;
        *)
            log_error "未知扫描类型: $scan_type"
            return 1
            ;;
    esac

    if [[ -n "$report_file" ]] && [[ -f "$report_file" ]]; then
        # 默认输出到控制台
        "${SCRIPTS_DIR}/report-generator.sh" --console "$report_file"

        # 保存报告文件路径
        echo "$report_file"
    else
        log_error "扫描失败，未生成报告"
        return 1
    fi
}

# 主函数
main() {
    local action="${1:-}"
    shift 2>/dev/null || true

    # 显示横幅（非 help/version）
    if [[ "$action" != "--help" ]] && [[ "$action" != "--version" ]]; then
        show_banner
    fi

    case "$action" in
        --quick|--deep|--intelligent|--auto)
            local report_file
            report_file=$(run_scan "${action#--}")

            # 检查是否需要特定输出格式
            if [[ "${1:-}" == "--output" ]]; then
                local output_format="${2:-console}"
                local output_file="${3:-}"

                case "$output_format" in
                    json)
                        "${SCRIPTS_DIR}/report-generator.sh" --json "$report_file" "$output_file"
                        ;;
                    markdown)
                        "${SCRIPTS_DIR}/report-generator.sh" --markdown "$report_file" "$output_file"
                        ;;
                    both)
                        "${SCRIPTS_DIR}/report-generator.sh" --both "$report_file" "$output_file"
                        ;;
                    *)
                        log_warning "未知输出格式: $output_format，使用默认控制台输出"
                        ;;
                esac
            fi
            ;;
        --list-rules)
            "${SCRIPTS_DIR}/rule-engine.sh" --list
            ;;
        --validate-rule)
            "${SCRIPTS_DIR}/rule-engine.sh" --validate "$@"
            ;;
        --load-rules)
            "${SCRIPTS_DIR}/rule-engine.sh" --load-all
            ;;
        --init-whitelist)
            "${SCRIPTS_DIR}/whitelist-manager.sh" --init
            ;;
        --add-whitelist-domain)
            shift
            "${SCRIPTS_DIR}/whitelist-manager.sh" --add-domain "$@"
            ;;
        --add-whitelist-path)
            shift
            "${SCRIPTS_DIR}/whitelist-manager.sh" --add-path "$@"
            ;;
        --list-whitelist)
            "${SCRIPTS_DIR}/whitelist-manager.sh" --list
            ;;
        --check-whitelist)
            "${SCRIPTS_DIR}/whitelist-manager.sh" --check
            ;;
        --version|--v)
            show_version
            ;;
        --help|--h|'')
            show_banner
            show_help
            ;;
        *)
            log_error "未知选项: $action"
            show_help
            exit 1
            ;;
    esac
}

# 执行主函数
main "$@"
