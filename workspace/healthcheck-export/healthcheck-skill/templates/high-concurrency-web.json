{
  "template_name": "high-concurrency-web",
  "version": "3.0.0",
  "description": "高并发Web服务器安全加固模板",
  "use_cases": ["电商网站", "API网关", "内容分发", "微服务入口"],
  "target_environment": "production",
  "performance_profile": "high",
  "security_level": "balanced",
  
  "system_requirements": {
    "min_memory_gb": 4,
    "recommended_memory_gb": 8,
    "min_cores": 2,
    "recommended_cores": 4
  },
  
  "sysctl_overrides": {
    "net.core.somaxconn": 65535,
    "net.ipv4.tcp_max_syn_backlog": 65535,
    "net.ipv4.tcp_fin_timeout": 30,
    "net.ipv4.tcp_keepalive_time": 300,
    "net.ipv4.tcp_tw_reuse": 1,
    "net.ipv4.ip_local_port_range": "1024 65535",
    "vm.swappiness": 10,
    "fs.file-max": 2097152,
    "fs.nr_open": 2097152
  },
  
  "security_settings": {
    "file_descriptor_limit": 65535,
    "tcp_keepalive": {
      "enabled": true,
      "time": 300,
      "interval": 30,
      "probes": 3
    },
    "connection_limits": {
      "max_connections_per_ip": 1000,
      "connection_timeout": 60
    }
  },
  
  "firewall_rules": {
    "allowed_ports": [80, 443],
    "rate_limiting": {
      "enabled": true,
      "requests_per_second": 100,
      "burst": 200
    },
    "ddos_protection": {
      "enabled": true,
      "max_connections": 10000,
      "block_threshold": 1000
    }
  },
  
  "service_hardening": {
    "nginx": {
      "worker_processes": "auto",
      "worker_connections": 65535,
      "keepalive_timeout": 65,
      "client_body_timeout": 12,
      "send_timeout": 10,
      "limit_req_zone": "$binary_remote_addr zone=one:10m rate=100r/s"
    },
    "apache": {
      "max_keep_alive_requests": 100,
      "keep_alive_timeout": 5,
      "max_request_workers": 400,
      "threads_per_child": 25
    }
  },
  
  "monitoring_alerts": {
    "cpu_threshold": 80,
    "memory_threshold": 85,
    "connection_threshold": 5000,
    "response_time_threshold": 1000
  },
  
  "performance_impact": {
    "security_overhead": "5-10%",
    "recommended_for": ["高流量网站", "API服务", "CDN节点"],
    "not_recommended_for": ["低流量静态网站", "开发测试环境"]
  },
  
  "compliance_notes": {
    "iso27001": "符合访问控制和可用性要求",
    "等级保护": "符合三级系统性能要求"
  }
}
